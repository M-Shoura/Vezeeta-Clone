@using Application.DTOs.Medical_Records
@model IEnumerable<MedicalRecordDto>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-file-medical"></i> Clinical records</span>
            <h1 class="page-title mt-2">Medical Records</h1>
            <p class="page-subtitle">Review diagnoses, conditions, and active patient history.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Medical Record
        </a>
    </div>

    <div class="section-card p-4">
        <table id="medicalRecordTable" class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Condition</th>
                    <th>Diagnosis Code</th>
                    <th>Diagnosed</th>
                    <th>Resolved</th>
                    <th>Status</th>
                    
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Condition</td>
                            <td><span class="status-badge status-muted">@item.DiagnosisCode</span></td>
                            <td>@item.DiagnosedDate.ToShortDateString()</td>
                            <td>@(item.ResolvedDate?.ToShortDateString() ?? "N/A")</td>
                            <td>
                                <span class="status-badge @(item.IsActive ? "status-success" : "status-muted")">
                                    @(item.IsActive ? "Active" : "Resolved")
                                </span>
                            </td>
                            
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal" onclick="setDeleteId(@item.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state my-2">
                                <i class="bi bi-file-medical"></i>
                                <p class="mt-2 mb-0">No medical records found.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">Are you sure you want to delete this record?</div>
            <div class="modal-footer">
                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setDeleteId(id) {
            document.getElementById("deleteId").value = id;
        }

        $(document).ready(function () {
            if ($.fn.DataTable) {
                $("#medicalRecordTable").DataTable();
            }
        });
    </script>
}
