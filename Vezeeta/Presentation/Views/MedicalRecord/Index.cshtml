@using Application.DTOs.Medical_Records
@model IEnumerable<MedicalRecordDto>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Medical Records</h2>

        <a asp-action="Create" class="btn btn-primary">
            Add Medical Record
        </a>
    </div>

    <table id="medicalRecordTable"
           class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>Condition</th>
                <th>Diagnosis Code</th>
                <th>Diagnosed Date</th>
                <th>Resolved Date</th>
                <th>Status</th>
                <th>Appointment Id</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Condition</td>

                    <td>@item.DiagnosisCode</td>

                    <td>
                        @item.DiagnosedDate.ToShortDateString()
                    </td>

                    <td>
                        @(item.ResolvedDate?.ToShortDateString() ?? "N/A")
                    </td>

                    <td>
                        @(item.IsActive ? "Active" : "Resolved")
                    </td>

                    <td>
                        @item.AppointmentId
                    </td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">

                            Edit

                        </a>

                        <button class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                onclick="setDeleteId(@item.Id)">

                            Delete

                        </button>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>


<div class="modal fade"
     id="deleteModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete this record?
            </div>

            <div class="modal-footer">

                <form asp-action="Delete" method="post">

                    <input type="hidden"
                           id="deleteId"
                           name="id" />

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Cancel

                    </button>

                    <button type="submit"
                            class="btn btn-danger">

                        Delete

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        function setDeleteId(id)
        {
            document.getElementById('deleteId').value = id;
        }

        $(document).ready(function ()
        {
            $('#medicalRecordTable').DataTable();
        });

    </script>
}
