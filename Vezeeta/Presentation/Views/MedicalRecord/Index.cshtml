@using Application.DTOs.Medical_Records
@model IEnumerable<MedicalRecordDto>

@{
    ViewData["Title"] = "Medical Records";
}

<div class="app-container">
    <div class="page-header animate-in border-bottom pb-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary-soft text-primary p-3 rounded-4">
                <i class="bi bi-file-medical fs-2"></i>
            </div>
            <div>
                <span class="eyebrow"><i class="bi bi-activity text-info"></i> Clinical records</span>
                <h1 class="page-title mt-1 mb-1">Medical History</h1>
                <p class="page-subtitle">Review diagnoses, conditions, and active patient history.</p>
            </div>
        </div>
        <div class="mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold px-4">
                <i class="bi bi-plus-lg me-2"></i> Add Record
            </a>
        </div>
    </div>

    <div class="section-card p-4 animate-in stagger-1">
        @if (Model.Any())
        {
            <div class="table-responsive border-0">
                <table id="medicalRecordTable" class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Condition</th>
                            <th>Code</th>
                            <th>Diagnosed</th>
                            <th>Resolved</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-body">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-sm bg-info bg-opacity-10 text-info rounded-circle"><i class="bi bi-clipboard2-pulse"></i></div>
                                        @item.Condition
                                    </div>
                                </td>
                                <td><span class="badge bg-surface-soft text-body border px-2 py-1"><i class="bi bi-upc me-1 text-muted"></i> @item.DiagnosisCode</span></td>
                                <td>
                                    <div class="fw-medium text-body">@item.DiagnosedDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td>
                                    @if (item.ResolvedDate.HasValue)
                                    {
                                        <div class="fw-medium text-muted">@item.ResolvedDate.Value.ToString("dd MMM yyyy")</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted opacity-50"><i class="bi bi-dash-lg"></i></span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(item.IsActive ? "status-success" : "status-muted") px-3 py-1">
                                        @(item.IsActive ? "Active" : "Resolved")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning shadow-sm" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger shadow-sm" data-bs-toggle="modal" data-bs-target="#deleteModal" onclick="setDeleteId(@item.Id)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state border-0 py-5">
                <i class="bi bi-file-earmark-medical text-muted opacity-25" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mt-3 text-body">No medical records</h5>
                <p class="text-muted mb-0">There is no clinical history recorded yet.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-0 fs-5">Are you sure you want to permanently delete this medical record?</p>
                <div class="text-muted small mt-2">This action removes the record from patient history.</div>
            </div>
            <div class="modal-footer border-0 bg-light p-3">
                <form asp-action="Delete" method="post" class="d-flex gap-2 w-100 justify-content-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger fw-bold px-4">Delete Record</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setDeleteId(id) {
            document.getElementById("deleteId").value = id;
        }

        $(document).ready(function () {
            if ($.fn.DataTable) {
                $("#medicalRecordTable").DataTable({
                    "dom": '<"d-flex justify-content-between align-items-center mb-3"lf>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                    "language": {
                        "search": "",
                        "searchPlaceholder": "Search records..."
                    }
                });
                
                // Style DataTable inputs to match design system
                $('.dataTables_filter input').addClass('form-control shadow-sm border-0 bg-light').css('margin-left', '10px');
                $('.dataTables_length select').addClass('form-select shadow-sm border-0 bg-light');
            }
        });
    </script>
}
