@using Application.DTOs.Medical_Records
@model MedicalRecordDto

@{
    ViewData["Title"] = "Edit Medical Record";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4>Edit Medical Record</h4>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <!-- Hidden fields - set by controller -->
                <input asp-for="Id" type="hidden" />
                <input asp-for="PatientId" type="hidden" />
                <input asp-for="AppointmentId" type="hidden" />

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="DiagnosedDate" class="form-label"></label>

                        <input asp-for="DiagnosedDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="DiagnosedDate"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="ResolvedDate" class="form-label"></label>

                        <input asp-for="ResolvedDate"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="ResolvedDate"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="mb-3">

                    <label asp-for="Condition" class="form-label"></label>

                    <input asp-for="Condition"
                           class="form-control" />

                    <span asp-validation-for="Condition"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Description" class="form-label"></label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="3"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger"></span>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="DiagnosisCode" class="form-label"></label>

                        <input asp-for="DiagnosisCode"
                               class="form-control" />

                        <span asp-validation-for="DiagnosisCode"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="IsActive" class="form-label"></label>

                        <div class="form-check mt-2">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="Treatment" class="form-label"></label>

                        <textarea asp-for="Treatment"
                                  class="form-control"
                                  rows="2"></textarea>

                        <span asp-validation-for="Treatment"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="Allergies" class="form-label"></label>

                        <textarea asp-for="Allergies"
                                  class="form-control"
                                  rows="2"></textarea>

                        <span asp-validation-for="Allergies"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="Medications" class="form-label"></label>

                        <textarea asp-for="Medications"
                                  class="form-control"
                                  rows="2"></textarea>

                        <span asp-validation-for="Medications"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="SurgeryDetails" class="form-label"></label>

                        <textarea asp-for="SurgeryDetails"
                                  class="form-control"
                                  rows="2"></textarea>

                        <span asp-validation-for="SurgeryDetails"
                              class="text-danger"></span>

                    </div>

                </div>

                <div class="mb-3">

                    <label asp-for="FamilyHistory" class="form-label"></label>

                    <textarea asp-for="FamilyHistory"
                              class="form-control"
                              rows="3"></textarea>

                    <span asp-validation-for="FamilyHistory"
                          class="text-danger"></span>

                </div>

                <div class="d-grid gap-2">

                    <button type="submit" class="btn btn-primary">
                        Update Medical Record
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
