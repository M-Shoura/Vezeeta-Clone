@model Application.DTOs.Dashboards.AdminDashboardViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
    var appointmentCount = Model.RecentAppointments?.Count ?? 0;
}

<section class="hero-panel p-4 p-xl-5 mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-lg-7">
            <span class="eyebrow text-white-50"><i class="fa-solid fa-shield-heart"></i> Command center</span>
            <h2 class="display-6 fw-bold mt-3 mb-2">Run every clinic workflow from one clear dashboard.</h2>
            <p class="mb-0 text-white-50">Monitor doctors, patients, appointments, revenue signals, and operational activity across the platform.</p>
        </div>
        <div class="col-lg-5">
            <div class="glass-panel p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-white-50 fw-bold">Completed revenue</small>
                        <div class="h2 fw-bold mb-0">EGP @Model.TotalRevenue.ToString("N0")</div>
                    </div>
                    <i class="fa-solid fa-wallet fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="stat-card doctors d-flex justify-content-between align-items-center">
            <div>
                <p>Total Doctors</p>
                <h2>@Model.DoctorsCount</h2>
                <span>Credentialed providers</span>
            </div>
            <i class="fa-solid fa-user-doctor"></i>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stat-card patients d-flex justify-content-between align-items-center">
            <div>
                <p>Total Patients</p>
                <h2>@Model.PatientsCount</h2>
                <span>Registered accounts</span>
            </div>
            <i class="fa-solid fa-users"></i>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stat-card clinics d-flex justify-content-between align-items-center">
            <div>
                <p>Total Clinics</p>
                <h2>@Model.ClinicsCount</h2>
                <span>Active locations</span>
            </div>
            <i class="fa-solid fa-hospital"></i>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="stat-card appointments d-flex justify-content-between align-items-center">
            <div>
                <p>Total Appointments</p>
                <h2>@Model.TotalAppointments</h2>
                <span>@Model.TodayAppointments booked today</span>
            </div>
            <i class="fa-solid fa-calendar-check"></i>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card appointments d-flex justify-content-between align-items-center">
            <div>
                <p>Pending</p>
                <h2>@Model.PendingAppointments</h2>
                <span>Awaiting action</span>
            </div>
            <i class="fa-solid fa-hourglass-half"></i>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card patients d-flex justify-content-between align-items-center">
            <div>
                <p>Completed</p>
                <h2>@Model.CompletedAppointments</h2>
                <span>Finished visits</span>
            </div>
            <i class="fa-solid fa-circle-check"></i>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="stat-card clinics d-flex justify-content-between align-items-center">
            <div>
                <p>This Month Revenue</p>
                <h2>@Model.MonthlyRevenue.ToString("N0")</h2>
                <span>EGP completed payments</span>
            </div>
            <i class="fa-solid fa-chart-pie"></i>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="admin-card p-4 h-100">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h5 class="fw-bold mb-1">Appointments & Revenue</h5>
                    <p class="text-muted mb-0">Monthly booking trend and projected revenue.</p>
                </div>
                <select id="chartRange" class="form-select w-auto">
                    <option value="year">This Year</option>
                    <option value="month">This Month</option>
                </select>
            </div>
            <div class="chart-box">
                <canvas id="appointmentsChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="admin-card p-4 h-100">
            <h5 class="fw-bold mb-1">Clinic Mix</h5>
            <p class="text-muted mb-4">Appointments by clinic.</p>
            <div class="chart-box">
                <canvas id="clinicChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-xl-8">
        <div class="admin-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <div>
                    <h5 class="fw-bold mb-1">Recent Appointments</h5>
                    <p class="text-muted mb-0">Latest bookings moving through the system.</p>
                </div>
                <a class="btn btn-primary btn-sm" asp-controller="Appointment" asp-action="Index">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> View all
                </a>
            </div>

            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Clinic</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentAppointments != null && Model.RecentAppointments.Any())
                    {
                        foreach (var appt in Model.RecentAppointments)
                        {
                            var statusClass = appt.Status.ToString().ToLowerInvariant() switch
                            {
                                "confirmed" => "status-success",
                                "pending" => "status-warning",
                                "completed" => "status-success",
                                _ => "status-muted"
                            };

                            <tr>
                                <td class="fw-semibold">@appt.PatientName</td>
                                <td>@appt.DoctorName</td>
                                <td>@appt.ClinicName</td>
                                <td><span class="status-badge @statusClass">@appt.Status</span></td>
                                <td>@appt.AppointmentDate.ToString("dd MMM yyyy, HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state my-2">
                                    <i class="fa-regular fa-calendar-xmark"></i>
                                    <p class="mt-2 mb-0">No recent appointments found.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="admin-card p-4 mb-4">
            <h5 class="fw-bold mb-3">Quick Actions</h5>
            <div class="d-grid gap-2">
                <a class="btn quick-action" asp-controller="Doctor" asp-action="Create">
                    <i class="fa-solid fa-user-doctor text-primary"></i> Add doctor
                </a>
                <a class="btn quick-action" asp-controller="Patient" asp-action="Create">
                    <i class="fa-solid fa-user-plus text-success"></i> Add patient
                </a>
                <a class="btn quick-action" asp-controller="Clinic" asp-action="Create">
                    <i class="fa-solid fa-hospital-user text-info"></i> Add clinic
                </a>
            </div>
        </div>

        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3">System Activity</h5>
            <div class="activity-item">
                <span class="activity-dot"></span>
                <div>
                    <div class="fw-bold">Appointment queue refreshed</div>
                    <small class="text-muted">Updated moments ago</small>
                </div>
            </div>
            <div class="activity-item">
                <span class="activity-dot bg-success"></span>
                <div>
                    <div class="fw-bold">Patient records synchronized</div>
                    <small class="text-muted">@Model.PatientsCount profiles available</small>
                </div>
            </div>
            <div class="activity-item">
                <span class="activity-dot bg-warning"></span>
                <div>
                    <div class="fw-bold">Clinic capacity review</div>
                    <small class="text-muted">@Model.ClinicsCount clinics in network</small>
                </div>
            </div>

            <div class="calendar-mini mt-4" aria-label="Calendar widget">
                @for (var day = 1; day <= 28; day++)
                {
                    <span class="@(day == DateTime.Today.Day ? "active" : "")">@day</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-xl-6">
        <div class="admin-card p-4 h-100">
            <h5 class="fw-bold mb-3">Recent Users</h5>
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentUsers.Any())
                    {
                        foreach (var user in Model.RecentUsers)
                        {
                            <tr>
                                <td class="fw-semibold">@user.FullName</td>
                                <td>@user.Email</td>
                                <td><span class="status-badge status-muted">@user.Role</span></td>
                                <td>@user.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4"><div class="empty-state my-2">No recent users found.</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="admin-card p-4 h-100">
            <h5 class="fw-bold mb-3">Top Doctors</h5>
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Doctor</th>
                        <th>Specialization</th>
                        <th>Appointments</th>
                        <th>Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TopDoctors.Any())
                    {
                        foreach (var doctor in Model.TopDoctors)
                        {
                            <tr>
                                <td class="fw-semibold">@doctor.DoctorName</td>
                                <td>@doctor.Specialization</td>
                                <td>@doctor.AppointmentCount</td>
                                <td>EGP @doctor.Revenue.ToString("N0")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4"><div class="empty-state my-2">No appointment trends yet.</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const appointmentSeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyAppointments));
        const revenueSeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenuePoints));
        const recentAppointments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentAppointments));
        const labels = appointmentSeries.map(point => point.Label);
        const appointments = appointmentSeries.map(point => point.Count);
        const revenue = revenueSeries.map(point => point.Amount);

        new Chart(document.getElementById("appointmentsChart"), {
            type: "line",
            data: {
                labels,
                datasets: [
                    {
                        label: "Appointments",
                        data: appointments,
                        borderWidth: 3,
                        tension: 0.42,
                        fill: true,
                        backgroundColor: "rgba(37,99,235,0.12)",
                        borderColor: "#2563eb"
                    },
                    {
                        label: "Revenue",
                        data: revenue,
                        borderWidth: 3,
                        tension: 0.42,
                        borderColor: "#14b8a6",
                        backgroundColor: "rgba(20,184,166,0.08)"
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { labels: { usePointStyle: true } } },
                scales: { y: { beginAtZero: true } }
            }
        });

        const clinics = (recentAppointments || []).reduce((acc, appointment) => {
            const key = appointment.ClinicName || "Unassigned";
            acc[key] = (acc[key] || 0) + 1;
            return acc;
        }, {});

        const clinicLabels = Object.keys(clinics);
        const clinicData = clinicLabels.map((key) => clinics[key]);

        new Chart(document.getElementById("clinicChart"), {
            type: "doughnut",
            data: {
                labels: clinicLabels.length ? clinicLabels : ["No clinic data"],
                datasets: [{
                    data: clinicData.length ? clinicData : [1],
                    backgroundColor: ["#2563eb", "#14b8a6", "#f59e0b", "#22c55e", "#ef4444"],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: "68%",
                plugins: { legend: { position: "bottom" } }
            }
        });
    </script>
}
