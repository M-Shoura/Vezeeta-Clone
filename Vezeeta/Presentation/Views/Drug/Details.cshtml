@model Application.DTOs.Drugs.DrugDto

@{
    ViewData["Title"] = "Drug Details";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-info text-white">
            <h3>Drug Details</h3>
        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Generic Name</dt>
                <dd class="col-sm-9">@Model.GenericName</dd>

                <dt class="col-sm-3">Manufacturer</dt>
                <dd class="col-sm-9">@Model.Manufacturer</dd>

                <dt class="col-sm-3">Strength</dt>
                <dd class="col-sm-9">@Model.Strength</dd>

                <dt class="col-sm-3">Side Effects</dt>
                <dd class="col-sm-9">@Model.SideEffects</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Price</dt>
                <dd class="col-sm-9">@Model.Price.ToString("C")</dd>

            </dl>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-warning">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </div>
    </div>
</div>