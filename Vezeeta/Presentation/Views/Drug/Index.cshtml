@model Application.DTOs.Drugs.DrugPagedResultDto

@{
    ViewData["Title"] = "Drugs";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-capsule"></i> Pharmacy catalog</span>
            <h1 class="page-title mt-2">Drugs</h1>
            <p class="page-subtitle">Search, review, and maintain medication records.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Add Drug
        </a>
    </div>

    <div class="section-card p-4 mb-4">
        <form class="row g-3 align-items-end" method="get" asp-action="Index">
            <div class="col-md-9">
                <label for="SearchInp" class="form-label">Search medications</label>
                <input type="text" name="search" id="SearchInp" value="@Model?.Search" placeholder="Search by name, manufacturer, or strength" class="form-control form-control-lg" />
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>
    </div>

    <div class="section-card p-4">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Generic</th>
                    <th>Description</th>
                    <th>Side Effect</th>
                    <th>Manufacturer</th>
                    <th>Strength</th>
                    <th>Price</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Items != null && Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.GenericName</td>
                            <td>@item.Description</td>
                            <td>@item.SideEffects</td>
                            <td>@item.Manufacturer</td>
                            <td><span class="status-badge status-muted">@item.Strength</span></td>
                            <td class="fw-bold">@item.Price.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@item.Id" data-name="@item.Name">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state my-2">
                                <i class="bi bi-capsule"></i>
                                <p class="mt-2 mb-0">No drugs found.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model != null && Model.TotalPages > 1)
        {
            var startPage = Math.Max(1, Model.PageNumber - 2);
            var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-4">
                <div class="text-muted">
                    Showing <strong>@(((Model.PageNumber - 1) * 10) + 1)</strong>
                    to <strong>@Math.Min(Model.PageNumber * 10, Model.TotalCount)</strong>
                    of <strong>@Model.TotalCount</strong> results
                </div>

                <nav aria-label="Drug page navigation">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-pageNumber="1">&laquo;</a>
                        </li>
                        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-pageNumber="@(Model.PageNumber - 1)">&lsaquo;</a>
                        </li>
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-pageNumber="@(Model.PageNumber + 1)">&rsaquo;</a>
                        </li>
                        <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-pageNumber="@Model.TotalPages">&raquo;</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="drugName"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteDrugId" name="id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById("deleteModal");
        deleteModal?.addEventListener("show.bs.modal", function (event) {
            const button = event.relatedTarget;
            document.getElementById("deleteDrugId").value = button.getAttribute("data-id");
            document.getElementById("drugName").textContent = button.getAttribute("data-name");
        });
    </script>
}
