@model Application.DTOs.Reviews.ReviewDto

@{
    ViewData["Title"] = "Review Details";
}

<div class="section-card p-4 p-lg-5 mx-auto" style="max-width: 760px;">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h2 class="mb-1">Review Details</h2>
            <p class="text-muted mb-0">Read-only summary of the submitted review.</p>
        </div>
        <span class="badge bg-light text-dark">Review #@Model.Id</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <dl class="row mb-0 gy-3">
        <dt class="col-sm-3 text-muted">Rating</dt>
        <dd class="col-sm-9 fw-semibold">@Model.Rating</dd>

        <dt class="col-sm-3 text-muted">Comment</dt>
        <dd class="col-sm-9">@Model.Comment</dd>

        <dt class="col-sm-3 text-muted">Doctor</dt>
        <dd class="col-sm-9">@Model.DoctorName</dd>

        <dt class="col-sm-3 text-muted">Patient</dt>
        <dd class="col-sm-9">@Model.PatientName</dd>

        <dt class="col-sm-3 text-muted">Created</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("f")</dd>
    </dl>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-secondary"
           asp-controller="@(ViewData["BackController"]?.ToString() ?? "Review")"
           asp-action="@(ViewData["BackAction"]?.ToString() ?? "Index")">
            @(ViewData["BackController"]?.ToString() == "Patient" ? "Back to dashboard" : "Back to list")
        </a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        @if (User.IsInRole("Patient") || User.IsInRole("Admin"))
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">Delete</button>
            </form>
        }
    </div>
</div>
