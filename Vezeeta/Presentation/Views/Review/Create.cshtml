@model Presentation.ViewModels.Reviews.ReviewCreateViewModel

@{
    ViewData["Title"] = "Add Review";
}

<div class="section-card p-4 mx-auto" style="max-width: 760px;">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h2 class="mb-1">Add Review</h2>
            <p class="text-muted mb-0">Only completed appointments can be reviewed.</p>
        </div>
        <span class="badge bg-light text-dark">Appointment #@Model.AppointmentId</span>
    </div>

    <form asp-action="Create" method="post" class="row g-3">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input asp-for="AppointmentId" type="hidden" />

        <div class="col-12">
            <fieldset class="rating-group">
                <legend class="form-label mb-2">Rating</legend>
                <div class="rating-stars" aria-label="Rating" role="radiogroup">
                    @for (var star = 1; star <= 5; star++)
                    {
                        var inputId = $"rating-{star}";

                        if (Model.Rating == star)
                        {
                            <input class="rating-input" type="radio" id="@inputId" name="Rating" value="@star" checked="checked" />
                        }
                        else
                        {
                            <input class="rating-input" type="radio" id="@inputId" name="Rating" value="@star" />
                        }

                        <label class="rating-star" for="@inputId" title="@star star@(star > 1 ? "s" : string.Empty)" aria-label="@star star@(star > 1 ? "s" : string.Empty)">
                            <i class="bi bi-star-fill"></i>
                        </label>
                    }
                </div>
                <small class="text-muted d-block mt-2">Select one to five stars.</small>
                <span asp-validation-for="Rating" class="text-danger d-block"></span>
            </fieldset>
        </div>

        <div class="col-12">
            <label asp-for="Comment" class="form-label">Comment</label>
            <textarea asp-for="Comment" class="form-control"></textarea>
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Create</button>
            <a class="btn btn-secondary" asp-controller="Patient" asp-action="Dashboard">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
