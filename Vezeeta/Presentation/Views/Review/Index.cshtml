@model IEnumerable<Application.DTOs.Reviews.ReviewDto>

@{
    ViewData["Title"] = "All Reviews";
}

<div class="app-container">
    <div class="page-header animate-in border-bottom pb-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary-soft text-primary p-3 rounded-4">
                <i class="bi bi-star-half fs-2"></i>
            </div>
            <div>
                <span class="eyebrow"><i class="bi bi-chat-heart text-info"></i> Review management</span>
                <h1 class="page-title mt-1 mb-1">Patient Reviews</h1>
                <p class="page-subtitle">View and manage all patient feedback for doctors and their services.</p>
            </div>
        </div>
    </div>

    <div class="section-card p-4 animate-in stagger-1">
        @if (Model.Any())
        {
            <div class="table-responsive border-0">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Rating</th>
                            <th>Feedback</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model)
                        {
                            <tr>
                                <td style="width: 140px;">
                                    <div class="rating-stars mb-0" style="font-size: 1rem; color: var(--warning)">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star text-muted opacity-25"></i>
                                            }
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <span class="text-truncate d-inline-block text-body fw-medium" style="max-width: 250px;" title="@review.Comment">
                                            "@review.Comment"
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted font-italic opacity-75">No comment provided</span>
                                    }
                                </td>
                                <td class="text-muted fw-medium"><i class="bi bi-person me-1 text-primary opacity-50"></i> @review.PatientName</td>
                                <td class="text-muted fw-medium"><i class="bi bi-person-badge me-1 text-info opacity-50"></i> @review.DoctorName</td>
                                <td class="text-muted">
                                    @review.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                                    <div class="small opacity-50 font-monospace">APT-#@review.AppointmentId</div>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@review.Id" class="btn btn-sm btn-light border shadow-sm fw-medium">Details</a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("admin"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" onclick="return confirm('Are you sure you want to permanently delete this review?');" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state border-0 py-5">
                <i class="bi bi-star text-muted opacity-25" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mt-3 text-body">No reviews found</h5>
                <p class="text-muted mb-0">Patients have not submitted any feedback yet.</p>
            </div>
        }
    </div>
</div>
