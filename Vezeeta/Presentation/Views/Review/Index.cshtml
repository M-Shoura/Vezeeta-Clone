@model IEnumerable<Application.DTOs.Reviews.ReviewDto>

@{
    ViewData["Title"] = "All Reviews";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-star"></i> Review management</span>
            <h1 class="page-title mt-2">All Reviews</h1>
            <p class="page-subtitle">View all patient reviews for doctors and their services.</p>
        </div>
    </div>

    <div class="section-card p-4">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Rating</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Comment</th>
                    <th>Appointment</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var review in Model)
                    {
                        <tr>
                            <td>
                                <div class="rating-display">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <i class="bi bi-star-fill @(i < review.Rating ? "text-warning" : "text-muted")"></i>
                                    }
                                    <span class="ms-2 fw-bold">@review.Rating/5</span>
                                </div>
                            </td>
                            <td>@review.PatientName</td>
                            <td>@review.DoctorName</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(review.Comment))
                                {
                                    <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@review.Comment">
                                        @review.Comment
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">No comment</span>
                                }
                            </td>
                            <td>#@review.AppointmentId</td>
                            <td>@review.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@review.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?');">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state my-2">
                                <i class="bi bi-star"></i>
                                <p class="mt-2 mb-0">No reviews found.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
