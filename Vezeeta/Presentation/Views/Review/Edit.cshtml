@model Presentation.ViewModels.Reviews.ReviewEditViewModel

@{
    ViewData["Title"] = "Edit Review";
}

<div class="section-card p-4 p-lg-5 mx-auto" style="max-width: 760px;">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h2 class="mb-1">Edit Review</h2>
            <p class="text-muted mb-0">Update your rating and comment.</p>
        </div>
        <span class="badge bg-light text-dark">Review #@Model.Id</span>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="Id" type="hidden" />
        <input asp-for="AppointmentId" type="hidden" />
        <input asp-for="DoctorId" type="hidden" />
        <input asp-for="PatientId" type="hidden" />

        <div class="col-md-4">
            <label asp-for="Rating" class="form-label"></label>
            <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Comment" class="form-label"></label>
            <textarea asp-for="Comment" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</div>
