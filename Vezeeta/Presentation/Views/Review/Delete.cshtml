@model Application.DTOs.Reviews.ReviewDto

@{
    ViewData["Title"] = "Delete Review";
}

<div class="section-card p-4 mx-auto" style="max-width: 760px;">
    <h2 class="mb-3">Delete Review</h2>

    <div class="alert alert-warning">Are you sure you want to delete this review?</div>

    <dl class="row mb-3">
        <dt class="col-sm-3 text-muted">Rating</dt>
        <dd class="col-sm-9 fw-semibold">@Model.Rating</dd>

        <dt class="col-sm-3 text-muted">Comment</dt>
        <dd class="col-sm-9">@Model.Comment</dd>

        <dt class="col-sm-3 text-muted">Doctor</dt>
        <dd class="col-sm-9">@Model.DoctorName</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </form>
</div>
