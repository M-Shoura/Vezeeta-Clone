@model IEnumerable<Domain.Entities.Clinic>

@{
    ViewData["Title"] = "Clinics";
    var isAdmin = User.IsInRole("Admin");
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-hospital"></i> Clinic network</span>
            <h1 class="page-title mt-2">Clinics</h1>
            <p class="page-subtitle">Locations, contact details, and operational status.</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Clinic
            </a>
        }
    </div>

    <div class="section-card p-4">
        @if (Model.Any())
        {
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clinic in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="icon-box teal" style="width:38px;height:38px;flex-basis:38px;"><i class="bi bi-hospital"></i></span>
                                    @clinic.Name
                                </div>
                            </td>
                            <td>@clinic.Address</td>
                            <td>@clinic.PhoneNumber</td>
                            <td>
                                <span class="status-badge @(clinic.IsActive ? "status-success" : "status-muted")">
                                    @(clinic.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@clinic.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@clinic.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@clinic.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-hospital"></i>
                <p class="mt-2 mb-0">No clinics found.</p>
            </div>
        }
    </div>
</div>
