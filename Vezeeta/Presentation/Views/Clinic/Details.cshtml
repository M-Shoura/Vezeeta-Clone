@model Domain.Entities.Clinic

@{
    ViewData["Title"] = "Clinic Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">@Model.Name</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>

    <dl class="row">
        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@Model.PhoneNumber</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@(Model.Email ?? "N/A")</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(Model.Description ?? "N/A")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
    </dl>

    <h2 class="h4 fw-bold mt-5">Assigned Doctors</h2>
    @if (Model.DoctorClinics.Any())
    {
        <ul class="list-group col-lg-7">
            @foreach (var doctorClinic in Model.DoctorClinics)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="d-flex align-items-center gap-2">
                        <img src="@ProfilePictureHelper.GetUrl(doctorClinic.Doctor.ApplicationUser.ProfilePicture, doctorClinic.Doctor.ApplicationUser.FullName, size: 80)"
                             class="rounded-circle"
                             width="38"
                             height="38"
                             style="object-fit:cover;" />
                        @doctorClinic.Doctor.ApplicationUser.FullName
                    </span>
                    <span>@doctorClinic.ConsultationFee.ToString("C")</span>
                </li>
            }
        </ul>
    }
    else
    {
        <div class="alert alert-info col-lg-7">No doctors assigned to this clinic.</div>
    }
</div>
