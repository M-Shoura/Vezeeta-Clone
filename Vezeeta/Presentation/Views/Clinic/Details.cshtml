@model Domain.Entities.Clinic

@{
    ViewData["Title"] = "Clinic Details";
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("admin");
}

<div class="app-container">
    <div class="page-header animate-in border-bottom pb-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary-soft text-primary p-3 rounded-4">
                <i class="bi bi-hospital fs-2"></i>
            </div>
            <div>
                <h1 class="fw-bold mb-1 display-6">@Model.Name</h1>
                <span class="status-badge @(Model.IsActive ? "status-success" : "status-muted") border-0 px-3 mt-1">
                    <i class="bi @(Model.IsActive ? "bi-check-circle-fill" : "bi-dash-circle") me-1"></i> @(Model.IsActive ? "Active Location" : "Inactive Location")
                </span>
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (isAdmin)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning shadow-sm fw-bold px-4">
                    <i class="bi bi-pencil me-1"></i> Edit Clinic
                </a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm fw-bold px-4">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-5 col-xl-4 animate-in stagger-1">
            <div class="section-card p-4 h-100">
                <h5 class="fw-bold mb-4">Contact Information</h5>
                
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex gap-3">
                        <div class="bg-surface-soft p-2 rounded-circle text-primary" style="width: 40px; height: 40px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-geo-alt fs-5"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em">Address</small>
                            <span class="text-body fw-medium">@Model.Address</span>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <div class="bg-surface-soft p-2 rounded-circle text-primary" style="width: 40px; height: 40px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-telephone fs-5"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em">Phone</small>
                            <span class="text-body fw-medium">@Model.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <div class="bg-surface-soft p-2 rounded-circle text-primary" style="width: 40px; height: 40px; display:flex; align-items:center; justify-content:center;">
                            <i class="bi bi-envelope fs-5"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em">Email</small>
                            <span class="text-body fw-medium">@(string.IsNullOrEmpty(Model.Email) ? "Not provided" : Model.Email)</span>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-muted opacity-25" />
                
                <h6 class="fw-bold mb-2">Description</h6>
                <p class="text-muted mb-0 lh-lg">
                    @(string.IsNullOrEmpty(Model.Description) ? "No description available for this clinic." : Model.Description)
                </p>
            </div>
        </div>

        <div class="col-lg-7 col-xl-8 animate-in stagger-2">
            <div class="section-card p-4 h-100">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-people-fill text-info fs-4"></i>
                    <h5 class="fw-bold mb-0">Assigned Doctors</h5>
                </div>
                
                @if (Model.DoctorClinics != null && Model.DoctorClinics.Any())
                {
                    <div class="row g-3">
                        @foreach (var doctorClinic in Model.DoctorClinics)
                        {
                            <div class="col-md-6">
                                <div class="card bg-surface border shadow-sm p-3 hover-lift h-100">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@ProfilePictureHelper.GetUrl(doctorClinic.Doctor?.ApplicationUser?.ProfilePicture, doctorClinic.Doctor?.ApplicationUser?.FullName, size: 80)"
                                             class="avatar shadow-sm border border-2 border-white"
                                             alt="@doctorClinic.Doctor?.ApplicationUser?.FullName" />
                                        <div>
                                            <h6 class="fw-bold mb-1 text-body">@doctorClinic.Doctor?.ApplicationUser?.FullName</h6>
                                            <div class="text-primary fw-bold mt-2 bg-primary-soft d-inline-block px-2 py-1 rounded-2" style="font-size: 0.85rem">
                                                Consultation: @doctorClinic.ConsultationFee.ToString("C")
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state border-0 bg-surface-soft py-5 rounded-4">
                        <i class="bi bi-person-x text-muted opacity-25" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold mt-3 text-body">No assigned doctors</h5>
                        <p class="text-muted mb-0">Doctors need to be assigned to this clinic by administrators.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
