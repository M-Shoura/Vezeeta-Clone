@model Domain.Entities.Clinic

@{
    ViewData["Title"] = "Edit Clinic";
}

<div class="app-container" style="max-width: 800px; margin: 0 auto;">
    <div class="page-header animate-in border-bottom pb-3 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-light text-muted mb-3 shadow-sm border fw-medium"><i class="bi bi-arrow-left me-1"></i> Back to Clinics</a>
        <h1 class="page-title"><i class="bi bi-pencil-square me-2 text-warning"></i> Edit Clinic</h1>
        <p class="page-subtitle">Update facility details and operational status.</p>
    </div>

    <div class="section-card p-4 p-md-5 animate-in stagger-1">
        <partial name="_ClinicForm" model="Model" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
