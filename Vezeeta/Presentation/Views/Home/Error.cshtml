@{
    ViewData["Title"] = "Something went wrong";
}

<div class="app-container">
    <div class="empty-state py-5">
        <i class="bi bi-exclamation-triangle"></i>
        <h1 class="h3 fw-bold mt-3">Something went wrong</h1>
        <p class="text-muted mb-4">The request could not be completed. Please try again or return to the homepage.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back Home</a>
    </div>
</div>
