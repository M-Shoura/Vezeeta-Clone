@{
    ViewData["Title"] = "Home";
}

<div class="app-container">
    <section class="hero-panel p-4 p-xl-5 mb-5">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <span class="eyebrow text-white-50"><i class="bi bi-heart-pulse"></i> Premium healthcare booking</span>
                <h1 class="display-5 fw-bold mt-3 mb-3">Find trusted doctors and manage care without the waiting-room chaos.</h1>
                <p class="lead text-white-50 mb-4">Book visits, track appointments, and keep your healthcare journey organized in a clean modern workspace.</p>
                <form asp-controller="Doctor" asp-action="Index" method="get" class="row g-2">
                    <div class="col-md-5">
                        <input class="form-control form-control-lg" name="name" placeholder="Doctor name" />
                    </div>
                    <div class="col-md-5">
                        <input class="form-control form-control-lg" name="specialization" placeholder="Specialization" />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button class="btn btn-warning btn-lg" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </form>
            </div>
            <div class="col-lg-5">
                <div class="glass-panel p-4">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="h2 fw-bold mb-0">24/7</div>
                            <small class="text-white-50">Smart booking</small>
                        </div>
                        <div class="col-6">
                            <div class="h2 fw-bold mb-0">3</div>
                            <small class="text-white-50">Role dashboards</small>
                        </div>
                        <div class="col-12">
                            <a asp-controller="Doctor" asp-action="Index" class="btn btn-light w-100">Explore Doctors</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-md-4">
            <article class="metric-card">
                <span class="icon-box"><i class="bi bi-calendar2-check"></i></span>
                <h5 class="fw-bold mt-3">Book faster</h5>
                <p class="text-muted mb-0">Search by doctor, specialization, or clinic and move straight to available appointments.</p>
            </article>
        </div>
        <div class="col-md-4">
            <article class="metric-card">
                <span class="icon-box teal"><i class="bi bi-shield-check"></i></span>
                <h5 class="fw-bold mt-3">Manage securely</h5>
                <p class="text-muted mb-0">Profiles, schedules, records, payments, and reviews use the app's existing secure workflows.</p>
            </article>
        </div>
        <div class="col-md-4">
            <article class="metric-card">
                <span class="icon-box green"><i class="bi bi-clipboard2-pulse"></i></span>
                <h5 class="fw-bold mt-3">Stay organized</h5>
                <p class="text-muted mb-0">Role-based dashboards keep admins, doctors, and patients focused on their next action.</p>
            </article>
        </div>
    </div>
</div>
