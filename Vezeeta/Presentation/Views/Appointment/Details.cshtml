@model Vezeeta.Application.DTOs.Appointments.AppointmentDto

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Appointment Details</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Appointment ID</h6>
                            <p class="fs-5">@Model.Id</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Status</h6>
                            <p>
                                @{
                                    var badgeClass = Model.Status switch
                                    {
                                        Vezeeta.Domain.Enums.AppointmentStatus.Pending => "bg-warning",
                                        Vezeeta.Domain.Enums.AppointmentStatus.Confirmed => "bg-info",
                                        Vezeeta.Domain.Enums.AppointmentStatus.Completed => "bg-success",
                                        Vezeeta.Domain.Enums.AppointmentStatus.Cancelled => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass" style="font-size: 1rem;">@Model.Status</span>
                            </p>
                        </div>
                    </div>

                    <hr>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Date</h6>
                            <p class="fs-5">@Model.AppointmentDate.ToString("dddd, MMMM dd, yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Time</h6>
                            <p class="fs-5">@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</p>
                        </div>
                    </div>

                    <hr>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Doctor</h6>
                            <p class="fs-5">@Model.DoctorName</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Patient</h6>
                            <p class="fs-5">@Model.PatientName</p>
                        </div>
                    </div>

                    <hr>

                    <div class="mb-3">
                        <h6 class="text-muted">Clinic</h6>
                        <p class="fs-5">@Model.ClinicName</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr>
                        <div class="mb-3">
                            <h6 class="text-muted">Notes</h6>
                            <p>@Model.Notes</p>
                        </div>
                    }

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted">Created On</h6>
                            <p class="small">
                                <strong>Date:</strong> @Model.CreatedOn.ToString("g")<br>
                                <strong>By:</strong> @Model.CreatedBy
                            </p>
                        </div>
                        @if (Model.LastModifiedOn.HasValue)
                        {
                            <div class="col-md-6">
                                <h6 class="text-muted">Last Modified</h6>
                                <p class="small">
                                    <strong>Date:</strong> @Model.LastModifiedOn?.ToString("g")<br>
                                    <strong>By:</strong> @Model.LastModifiedBy
                                </p>
                            </div>
                        }
                    </div>

                    <hr>

                    <div class="d-flex gap-2">
                        @if (Model.Status == Vezeeta.Domain.Enums.AppointmentStatus.Pending || 
                             Model.Status == Vezeeta.Domain.Enums.AppointmentStatus.Confirmed)
                        {
                            <a href="/Appointment/Edit/@Model.Id" class="btn btn-warning">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <form method="post" action="/Appointment/Cancel/@Model.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger" 
                                    onclick="return confirm('Are you sure you want to cancel this appointment?');">
                                    <i class="fas fa-times"></i> Cancel
                                </button>
                            </form>
                        }
                        <a href="/Appointment" class="btn btn-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
