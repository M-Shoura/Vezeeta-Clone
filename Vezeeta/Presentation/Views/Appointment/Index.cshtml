@model IEnumerable<Vezeeta.Application.DTOs.Appointments.AppointmentDto>

@{
    ViewData["Title"] = "Appointments";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2 class="mb-4">Appointments List</h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="mb-3">
                <a class="btn btn-primary" href="/Appointment/Create">+ Book New Appointment</a>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Date & Time</th>
                                <th>Doctor</th>
                                <th>Patient</th>
                                <th>Clinic</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@appointment.AppointmentDate.ToString("MMM dd, yyyy")</strong><br>
                                        @appointment.StartTime.ToString(@"hh\:mm") - @appointment.EndTime.ToString(@"hh\:mm")
                                    </td>
                                    <td>@appointment.DoctorName</td>
                                    <td>@appointment.PatientName</td>
                                    <td>@appointment.ClinicName</td>
                                    <td>
                                        @{
                                            var badgeClass = appointment.Status switch
                                            {
                                                Vezeeta.Domain.Enums.AppointmentStatus.Pending => "bg-warning",
                                                Vezeeta.Domain.Enums.AppointmentStatus.Confirmed => "bg-info",
                                                Vezeeta.Domain.Enums.AppointmentStatus.Completed => "bg-success",
                                                Vezeeta.Domain.Enums.AppointmentStatus.Cancelled => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@appointment.Status</span>
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-info" href="/Appointment/Details/@appointment.Id" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (appointment.Status == Vezeeta.Domain.Enums.AppointmentStatus.Pending || 
                                             appointment.Status == Vezeeta.Domain.Enums.AppointmentStatus.Confirmed)
                                        {
                                            <a class="btn btn-sm btn-warning" href="/Appointment/Edit/@appointment.Id" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" action="/Appointment/Cancel/@appointment.Id" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger" title="Cancel" 
                                                    onclick="return confirm('Are you sure you want to cancel this appointment?');">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No appointments found. <a href="/Appointment/Create">Book one now</a>
                </div>
            }
        </div>
    </div>
</div>
