@model Domain.Entities.Appointment

@{
    ViewData["Title"] = "Booking Confirmation";
}

<div class="container mt-4">
    <div class="alert alert-success">
        Appointment booked successfully.
    </div>

    <h4>Details</h4>
    <ul>
        <li>Doctor: @Model.DoctorId</li>
        <li>Date: @Model.AppointmentDate.ToShortDateString()</li>
        <li>Time: @Model.StartTime - @Model.EndTime</li>
        <li>Clinic Id: @Model.ClinicId</li>
    </ul>

    <a class="btn btn-primary" asp-controller="Doctor" asp-action="Details" asp-route-id="@Model.DoctorId">Back to Doctor</a>
</div>
