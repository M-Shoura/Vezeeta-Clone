@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string IsActive(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<aside class="sidebar" aria-label="Admin navigation">
    <div class="sidebar-header">
        <div class="logo-box">
            <i class="fa-solid fa-heart-pulse"></i>
            <div>
                <h4>Vezeeta</h4>
                <span>Healthcare OS</span>
            </div>
        </div>
    </div>

    <ul class="sidebar-menu">
        <li>
            <a asp-controller="Admin" asp-action="Index" class="@IsActive("Admin")">
                <i class="fa-solid fa-chart-line"></i>
                <span>Dashboard</span>
            </a>
        </li>
        <li>
            <a asp-controller="Doctor" asp-action="Index" class="@IsActive("Doctor")">
                <i class="fa-solid fa-user-doctor"></i>
                <span>Doctors</span>
            </a>
        </li>
        <li>
            <a asp-controller="Patient" asp-action="Index" class="@IsActive("Patient")">
                <i class="fa-solid fa-users"></i>
                <span>Patients</span>
            </a>
        </li>
        <li>
            <a asp-controller="Appointment" asp-action="Index" class="@IsActive("Appointment")">
                <i class="fa-solid fa-calendar-check"></i>
                <span>Appointments</span>
            </a>
        </li>
        <li>
            <a asp-controller="Clinic" asp-action="Index" class="@IsActive("Clinic")">
                <i class="fa-solid fa-hospital"></i>
                <span>Clinics</span>
            </a>
        </li>
        <li>
            <a asp-controller="Drug" asp-action="Index" class="@IsActive("Drug")">
                <i class="fa-solid fa-pills"></i>
                <span>Drugs</span>
            </a>
        </li>
        <li>
            <a asp-controller="Payment" asp-action="Index" class="@IsActive("Payment")">
                <i class="fa-solid fa-credit-card"></i>
                <span>Payments</span>
            </a>
        </li>
        <li>
            <a asp-controller="Review" asp-action="Index" class="@IsActive("Review")">
                <i class="fa-solid fa-star"></i>
                <span>Reviews</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-footer">
        <small class="text-uppercase text-white-50 fw-bold">System health</small>
        <div class="d-flex align-items-center justify-content-between mt-2">
            <span class="fw-bold text-white">Operational</span>
            <span class="status-badge status-success">Live</span>
        </div>
    </div>
</aside>
