@{
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    var action = ViewContext.RouteData.Values["Action"]?.ToString();
    string IsActive(string c, string a = "Index") => controller == c && action == a ? "active" : "";
}

<aside class="sidebar">
    <div class="sidebar-header d-flex justify-content-between align-items-center">
        <a asp-controller="Home" asp-action="Index" class="logo-box text-decoration-none">
            <i class="bi bi-heart-pulse-fill"></i>
            <div>
                <h4>Taybat</h4>
                <span>Workspace</span>
            </div>
        </a>
        <button class="sidebar-toggle btn btn-sm text-white-50 p-0 border-0 shadow-none d-lg-none" data-sidebar-toggle aria-label="Close sidebar">
            <i class="bi bi-x-lg fs-4"></i>
        </button>
    </div>

    <div class="sidebar-body">
        <ul class="sidebar-menu">
            <li class="sidebar-menu-header">Main</li>

            @if (User.IsInRole("Admin") || User.IsInRole("admin"))
            {
                <li>
                    <a asp-controller="Admin" asp-action="Index" class="@IsActive("Admin", "Index")">
                        <i class="bi bi-grid-1x2"></i> Overview
                    </a>
                </li>
                
                <li class="sidebar-menu-header">Management</li>
                <li>
                    <a asp-controller="Doctor" asp-action="Index" class="@IsActive("Doctor")">
                        <i class="bi bi-person-badge"></i> Doctors
                    </a>
                </li>
                <li>
                    <a asp-controller="Patient" asp-action="Index" class="@IsActive("Patient")">
                        <i class="bi bi-people"></i> Patients
                    </a>
                </li>
                <li>
                    <a asp-controller="Clinic" asp-action="Index" class="@IsActive("Clinic")">
                        <i class="bi bi-hospital"></i> Clinics
                    </a>
                </li>
                <li>
                    <a asp-controller="Appointment" asp-action="Index" class="@IsActive("Appointment")">
                        <i class="bi bi-calendar-check"></i> Appointments
                    </a>
                </li>
                
                <li class="sidebar-menu-header">Clinical Data</li>
                <li>
                    <a asp-controller="Drug" asp-action="Index" class="@IsActive("Drug")">
                        <i class="bi bi-capsule"></i> Drugs Registry
                    </a>
                </li>
                <li>
                    <a asp-controller="MedicalRecord" asp-action="Index" class="@IsActive("MedicalRecord")">
                        <i class="bi bi-file-medical"></i> Medical Records
                    </a>
                </li>
                <li>
                    <a asp-controller="Prescription" asp-action="Index" class="@IsActive("Prescription")">
                        <i class="bi bi-prescription2"></i> Prescriptions
                    </a>
                </li>

                <li class="sidebar-menu-header">Finance & Feedback</li>
                <li>
                    <a asp-controller="Payment" asp-action="Index" class="@IsActive("Payment")">
                        <i class="bi bi-credit-card"></i> Payments
                    </a>
                </li>
                <li>
                    <a asp-controller="Review" asp-action="Index" class="@IsActive("Review")">
                        <i class="bi bi-star"></i> Reviews
                    </a>
                </li>
            }
            else if (User.IsInRole("Doctor") || User.IsInRole("doctor"))
            {
                <li>
                    <a asp-controller="Doctor" asp-action="Dashboard" class="@IsActive("Doctor", "Dashboard")">
                        <i class="bi bi-grid-1x2"></i> Workspace
                    </a>
                </li>
                
                <li class="sidebar-menu-header">My Practice</li>
                <li>
                    <a asp-controller="Appointment" asp-action="Index" class="@IsActive("Appointment")">
                        <i class="bi bi-calendar-check"></i> Schedule
                    </a>
                </li>
                <li>
                    <a asp-controller="MedicalRecord" asp-action="Index" class="@IsActive("MedicalRecord")">
                        <i class="bi bi-file-medical"></i> Patient Records
                    </a>
                </li>
                <li>
                    <a asp-controller="Prescription" asp-action="Index" class="@IsActive("Prescription")">
                        <i class="bi bi-prescription2"></i> Prescriptions
                    </a>
                </li>
            }
        </ul>
    </div>

    <div class="sidebar-footer">
        <div class="status-box">
            <div class="d-flex align-items-center gap-2">
                <div class="activity-dot shadow-none mt-0"></div>
                <span>System Online</span>
            </div>
            <i class="bi bi-cloud-check text-success"></i>
        </div>
    </div>
</aside>
