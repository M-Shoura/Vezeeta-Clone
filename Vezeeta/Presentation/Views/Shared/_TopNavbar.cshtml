@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "User";
    var roleName = User.IsInRole("Admin")
        ? "Administrator"
        : User.IsInRole("Doctor")
            ? "Doctor"
            : User.IsInRole("Patient")
                ? "Patient"
                : "User";
}

<nav class="navbar navbar-expand bg-white shadow-sm px-4 py-3">

    <div class="container-fluid">

        <div>

            <h5 class="mb-0 fw-bold">
                @ViewData["Title"]
            </h5>

        </div>

        <div class="d-flex align-items-center gap-4">

            <button class="btn position-relative">

                <i class="fa-solid fa-bell fs-5"></i>

                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    3
                </span>

            </button>

            <div class="d-flex align-items-center gap-2">

                <img src="@ProfilePictureHelper.GetUrl(currentUser?.ProfilePicture, displayName, size: 90)"
                     class="rounded-circle"
                     width="45"
                     height="45"
                     style="object-fit:cover;" />

                <div>
                    <h6 class="mb-0">@displayName</h6>
                    <small class="text-muted">@roleName</small>
                </div>

            </div>

        </div>

    </div>

</nav>
