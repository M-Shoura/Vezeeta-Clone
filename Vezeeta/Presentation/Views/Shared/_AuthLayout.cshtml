<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Vezeeta</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="auth-page py-4">
        <div class="auth-shell">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mb-3">@TempData["Success"]</div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mb-3">@TempData["Error"]</div>
            }

            <div class="row g-4 align-items-stretch">
                <div class="col-lg-5 d-none d-lg-block">
                    <section class="auth-visual p-4 p-xl-5 d-flex flex-column justify-content-between">
                        <a asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-2 text-white fw-bold">
                            <i class="bi bi-heart-pulse-fill fs-3"></i>
                            <span>Vezeeta Care</span>
                        </a>

                        <div>
                            <span class="eyebrow text-white-50">Healthcare access</span>
                            <h1 class="display-6 fw-bold mt-3 mb-3">One secure place for doctors, patients, and care teams.</h1>
                            <div class="glass-panel p-3">
                                <div class="d-flex align-items-center gap-3">
                                    <i class="bi bi-shield-check fs-3"></i>
                                    <p class="mb-0">Protected appointments, clear records, and faster patient journeys.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="col-lg-7 d-flex align-items-center">
                    <div class="w-100">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
