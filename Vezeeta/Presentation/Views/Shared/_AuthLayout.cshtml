<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Taybat</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="auth-page py-4">
        <div class="auth-shell animate-in">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm mb-4 animate-fade">
                    <i class="bi bi-check-circle-fill"></i>
                    <div>@TempData["Success"]</div>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm mb-4 animate-fade">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }

            <div class="row g-0 bg-surface rounded-4 shadow-xl overflow-hidden" style="min-height: 600px;">
                <div class="col-lg-5 d-none d-lg-block position-relative">
                    <section class="auth-visual h-100 p-4 p-xl-5 d-flex flex-column justify-content-between rounded-0">
                        <a asp-controller="Home" asp-action="Index" class="d-inline-flex align-items-center gap-2 text-white fw-bold fs-5 text-decoration-none z-3">
                            <div class="bg-white bg-opacity-25 p-2 rounded-3">
                                <i class="bi bi-heart-pulse-fill"></i>
                            </div>
                            <span>Taybat Care</span>
                        </a>

                        <div class="z-3 mb-4">
                            <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.75rem;">Healthcare Access</span>
                            <h1 class="display-6 fw-bold mt-2 mb-4 text-white" style="line-height: 1.1;">One secure place for doctors, patients, and care teams.</h1>
                            <div class="glass p-3 rounded-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-white bg-opacity-25 p-2 rounded-circle">
                                        <i class="bi bi-shield-check fs-4"></i>
                                    </div>
                                    <p class="mb-0 text-white fw-medium">Protected appointments, clear records, and faster patient journeys.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="col-lg-7 d-flex align-items-center bg-body">
                    <div class="w-100 p-4 p-md-5">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
