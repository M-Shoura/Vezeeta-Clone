@inject UserManager<ApplicationUser> UserManager

@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUser = isAuthenticated ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "Guest";
    var dashboardController = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Doctor") ? "Doctor" : User.IsInRole("Patient") ? "Patient" : "Home";
    var dashboardAction = User.IsInRole("Admin") ? "Index" : User.IsInRole("Doctor") || User.IsInRole("Patient") ? "Dashboard" : "Index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)">
    <title>@ViewData["Title"] - Taybat</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/Images/icon.png" />
</head>
<body>
    <div class="app-shell">
        <header class="app-navbar">
            <nav class="navbar navbar-expand-lg py-3">
                <div class="app-container d-flex align-items-center gap-3">
                    <a class="navbar-brand me-lg-4 d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index" aria-label="Taybat home">
                        <div class="bg-primary p-2 rounded-3 d-inline-flex">
                            <i class="bi bi-heart-pulse-fill text-white fs-5"></i>
                        </div>
                        <span class="fw-bold fs-5 d-none d-sm-block text-body">Taybat</span>
                    </a>

                    <button class="navbar-toggler border-0 shadow-none p-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list fs-3"></i>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <form class="navbar-search d-none d-lg-block me-auto" asp-controller="Doctor" asp-action="Index" method="get">
                            <i class="bi bi-search"></i>
                            <input class="form-control" type="search" name="name" placeholder="Search doctors, clinics..." aria-label="Search doctors" />
                        </form>

                        <ul class="navbar-nav align-items-lg-center gap-2 ms-lg-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Doctor" asp-action="Index">
                                    <i class="bi bi-search-heart"></i> Find Doctors
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Clinic" asp-action="Index">
                                    <i class="bi bi-hospital"></i> Clinics
                                </a>
                            </li>

                            <li class="nav-item d-none d-lg-block">
                                <span class="text-muted opacity-25">|</span>
                            </li>

                            <li class="nav-item">
                                <button class="btn btn-light rounded-circle p-2 d-flex align-items-center justify-content-center border-0" style="width:40px;height:40px" type="button" data-theme-toggle aria-label="Toggle theme">
                                    <i class="bi bi-moon"></i>
                                </button>
                            </li>

                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="btn btn-primary btn-sm px-3 ms-lg-2" asp-controller="@dashboardController" asp-action="@dashboardAction">
                                        <i class="bi bi-grid-1x2 me-1"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item dropdown ms-lg-2">
                                    <button class="btn btn-light dropdown-toggle px-3 d-flex align-items-center gap-2 border-0 bg-transparent" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <img src="@ProfilePictureHelper.GetUrl(currentUser?.ProfilePicture, displayName, size: 80)"
                                             class="avatar-sm" alt="@displayName" />
                                        <span class="d-none d-md-inline fw-semibold text-body">@displayName</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2 mt-2 animate-in" style="animation-duration: 0.2s">
                                        <li><a class="dropdown-item rounded-3 py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                        <li><a class="dropdown-item rounded-3 py-2" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-shield-lock me-2"></i>Security</a></li>
                                        <li><hr class="dropdown-divider opacity-10 my-2" /></li>
                                        <li><a class="dropdown-item rounded-3 py-2 text-danger fw-semibold" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item ms-lg-2">
                                    <a class="btn btn-light fw-semibold" asp-controller="Account" asp-action="Login">Login</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary fw-semibold px-4" asp-controller="Account" asp-action="Register">Sign Up</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="app-main py-4 animate-in">
            @RenderBody()
        </main>

        <footer class="app-footer pt-5 pb-4 mt-auto">
            <div class="app-container">
                <div class="row g-4 mb-4">
                    <div class="col-lg-4 footer-brand">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-heart-pulse-fill fs-3 text-primary"></i>
                            <h4 class="text-white mb-0 fw-bold">Taybat</h4>
                        </div>
                        <p class="mb-0 text-white-50 pe-lg-4">Premium healthcare booking, clinic operations, and patient care in one calm, secure workspace.</p>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="text-white fw-bold mb-3 text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em">Platform</h6>
                        <ul class="list-unstyled d-grid gap-2">
                            <li><a asp-controller="Doctor" asp-action="Index">Find Doctors</a></li>
                            <li><a asp-controller="Clinic" asp-action="Index">Explore Clinics</a></li>
                            <li><a asp-controller="Home" asp-action="Index">How it works</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="text-white fw-bold mb-3 text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em">Account</h6>
                        <ul class="list-unstyled d-grid gap-2">
                            <li><a asp-controller="Account" asp-action="Login">Sign In</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Create Account</a></li>
                            <li><a asp-controller="Account" asp-action="Profile">Manage Profile</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="text-white fw-bold mb-3 text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em">Get the App</h6>
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <img src="~/Images/google-play.png" alt="Google Play" class="store-badge" />
                            <img src="~/Images/app-store.png" alt="App Store" class="store-badge" />
                        </div>
                        <div class="d-flex gap-3 fs-5">
                            <a href="#" class="text-white-50 hover-white transition" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="text-white-50 hover-white transition" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="text-white-50 hover-white transition" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                            <a href="#" class="text-white-50 hover-white transition" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                        </div>
                    </div>
                </div>
                <div class="border-top border-secondary-subtle mt-4 pt-4 d-flex flex-wrap justify-content-between align-items-center text-white-50 gap-3" style="border-color: rgba(255,255,255,0.1) !important">
                    <small>&copy; @DateTime.Now.Year Taybat Clone. All Rights Reserved.</small>
                    <div class="d-flex gap-3 small">
                        <a href="#">Privacy Policy</a>
                        <a href="#">Terms of Service</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
