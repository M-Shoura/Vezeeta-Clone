@inject UserManager<ApplicationUser> UserManager

@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var currentUser = isAuthenticated ? await UserManager.GetUserAsync(User) : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "Guest";
    var dashboardController = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Doctor") ? "Doctor" : User.IsInRole("Patient") ? "Patient" : "Home";
    var dashboardAction = User.IsInRole("Admin") ? "Index" : User.IsInRole("Doctor") || User.IsInRole("Patient") ? "Dashboard" : "Index";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vezeeta</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/Images/icon.png" />
</head>
<body>
    <div class="app-shell">
        <header class="app-navbar">
            <nav class="navbar navbar-expand-lg py-3">
                <div class="app-container d-flex align-items-center gap-3">
                    <a class="bg-primary p-3 rounded-4 navbar-brand me-lg-4" asp-controller="Home" asp-action="Index" aria-label="Vezeeta home">
                        <img src="~/Images/logo.png" alt="Vezeeta Logo" />
                    </a>

                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <form class="navbar-search d-none d-lg-block me-auto" asp-controller="Doctor" asp-action="Index" method="get">
                            <i class="bi bi-search"></i>
                            <input class="form-control" type="search" name="name" placeholder="Search doctors, clinics..." aria-label="Search doctors" />
                        </form>

                        <ul class="navbar-nav align-items-lg-center gap-1 ms-lg-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Doctor" asp-action="Index">
                                    <i class="bi bi-search-heart"></i> Find Doctors
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill" asp-controller="Clinic" asp-action="Index">
                                    <i class="bi bi-hospital"></i> Clinics
                                </a>
                            </li>

                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-pill" asp-controller="@dashboardController" asp-action="@dashboardAction">
                                        <i class="bi bi-grid-1x2"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item dropdown">
                                    <button class="btn btn-light dropdown-toggle px-3" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <img src="@ProfilePictureHelper.GetUrl(currentUser?.ProfilePicture, displayName, size: 80)"
                                             class="avatar-sm" alt="@displayName" />
                                        <span class="d-none d-md-inline">@displayName</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2">
                                        <li><a class="dropdown-item rounded-3" asp-controller="Account" asp-action="Profile">Profile</a></li>
                                        <li><a class="dropdown-item rounded-3" asp-controller="Account" asp-action="ChangePassword">Security</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item rounded-3 text-danger" asp-controller="Account" asp-action="Logout">Logout</a></li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-pill" asp-controller="Account" asp-action="Login">Login</a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary px-4" asp-controller="Account" asp-action="Register">Sign Up</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="app-main py-4">
            @RenderBody()
        </main>

        <footer class="app-footer pt-5 pb-4">
            <div class="app-container">
                <div class="row g-4">
                    <div class="col-lg-4 footer-brand">
                        <img src="~/Images/logo.png" alt="Vezeeta Logo" class="mb-3" />
                        <p class="mb-0 text-white-50">Premium healthcare booking, clinic operations, and patient care in one calm workspace.</p>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="text-white fw-bold mb-3">Explore</h6>
                        <ul class="list-unstyled d-grid gap-2">
                            <li><a asp-controller="Doctor" asp-action="Index">Doctors</a></li>
                            <li><a asp-controller="Clinic" asp-action="Index">Clinics</a></li>
                            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-lg-2">
                        <h6 class="text-white fw-bold mb-3">Account</h6>
                        <ul class="list-unstyled d-grid gap-2">
                            <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                            <li><a asp-controller="Account" asp-action="Profile">Profile</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4">
                        <h6 class="text-white fw-bold mb-3">Download App</h6>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <img src="~/Images/google-play.png" alt="Google Play" class="store-badge" />
                            <img src="~/Images/app-store.png" alt="App Store" class="store-badge" />
                        </div>
                        <div class="d-flex gap-3 fs-5 text-white-50">
                            <span aria-label="Facebook"><i class="bi bi-facebook"></i></span>
                            <span aria-label="Instagram"><i class="bi bi-instagram"></i></span>
                            <span aria-label="Twitter"><i class="bi bi-twitter-x"></i></span>
                        </div>
                    </div>
                </div>
                <div class="border-top border-secondary-subtle mt-4 pt-4 text-center text-white-50">
                    <small>&copy; 2026 Vezeeta Clone. All Rights Reserved.</small>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
