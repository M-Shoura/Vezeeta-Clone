@model Application.DTOs.Doctors.DoctorDetailsDto

@{
    ViewData["Title"] = "Doctor Details";
    var availableSlots =
        ViewBag.AvailableSlots as IEnumerable<Application.DTOs.Appointments.AvailableSlotDto>
        ?? Enumerable.Empty<Application.DTOs.Appointments.AvailableSlotDto>();
    var appointments =
        ViewBag.Appointments as IEnumerable<Domain.Entities.Appointment>
        ?? Enumerable.Empty<Domain.Entities.Appointment>();
    var isPatient = User.IsInRole("Patient") || User.IsInRole("patient");
    var canManageDoctor =
        User.IsInRole("Admin")
        || User.IsInRole("admin")
        || User.IsInRole("Doctor")
        || User.IsInRole("doctor");
    var availabilityButtonClass =
        Model.IsAvailable
            ? "btn-danger"
            : "btn-success";
    var availabilityButtonText =
        Model.IsAvailable
            ? "Mark Unavailable"
            : "Mark Available";
}

<div class="app-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm mb-4 animate-fade" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <div>@TempData["Success"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm mb-4 animate-fade" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="hero-panel p-4 p-xl-5 mb-5 animate-in">
        <div class="row align-items-center g-5">
            <div class="col-md-3 text-center position-relative z-1">
                <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 240)"
                     alt="Dr. @Model.FullName"
                     class="rounded-circle shadow-lg border border-4 border-white"
                     style="width: 200px; height: 200px; object-fit:cover;" />
            </div>

            <div class="col-md-9 position-relative z-1">
                <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                    <span class="badge bg-white text-primary px-3 py-2 rounded-pill fw-bold" style="font-size: 0.85rem;">
                        <i class="bi bi-star-fill text-warning me-1"></i> @Model.Specialization
                    </span>
                    <span class="status-badge px-3 py-2 border-0 @(Model.IsAvailable ? "bg-success text-white" : "bg-danger text-white") shadow-sm" style="font-size: 0.85rem">
                        <i class="bi @(Model.IsAvailable ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                        @(Model.IsAvailable ? "Available Now" : "Currently Unavailable")
                    </span>
                </div>

                <h1 class="display-5 fw-bold text-white mt-3 mb-2">Dr. @Model.FullName</h1>
                
                <div class="d-flex align-items-center gap-4 text-white-50 fs-5 mb-4">
                    <span><i class="bi bi-award me-2"></i>@Model.YearsOfExperience Years Experience</span>
                    <span><i class="bi bi-mortarboard me-2"></i>@Model.Qualification</span>
                </div>

                <div class="glass p-4 rounded-4 shadow-sm mb-4">
                    <p class="mb-0 text-white fw-medium lh-lg">@Model.Bio</p>
                </div>

                @if (canManageDoctor)
                {
                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <a asp-action="Dashboard" asp-route-id="@Model.Id" class="btn btn-light fw-bold shadow-sm">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-light fw-bold">
                            <i class="bi bi-pencil"></i> Edit Profile
                        </a>
                        <a asp-action="Schedules" asp-route-id="@Model.Id" class="btn btn-outline-light fw-bold">
                            <i class="bi bi-calendar3"></i> Manage Schedules
                        </a>
                        <a asp-action="AssignClinic" asp-route-id="@Model.Id" class="btn btn-outline-light fw-bold">
                            <i class="bi bi-hospital"></i> Assign Clinic
                        </a>
                        <form asp-action="ToggleAvailability" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="isAvailable" value="@(!Model.IsAvailable)" />
                            <button type="submit" class="btn @availabilityButtonClass fw-bold shadow-sm">
                                <i class="bi bi-power"></i> @availabilityButtonText
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </section>

    @{
        var slotsByDay = availableSlots
            .GroupBy(s => s.Date.Date)
            .OrderBy(g => g.Key)
            .ToList();
    }

    <div class="slots-section mb-5 animate-in stagger-2">
        <div class="slots-header mb-4 border-bottom pb-4">
            <div>
                <p class="eyebrow"><i class="bi bi-calendar-check"></i> Appointment Booking</p>
                <h3 class="display-6 fw-bold mb-0">Available Slots</h3>
            </div>
            <span class="slots-total-badge px-4 py-2 fs-6 shadow-sm"><i class="bi bi-check-circle-fill me-2"></i> @availableSlots.Count() slots available</span>
        </div>

        @if (slotsByDay.Any())
        {
            <div class="day-navigator mb-4 shadow-sm bg-surface p-3 border rounded-4" id="dayNavigator">
                <button class="day-nav-btn shadow-sm" id="prevDayBtn" onclick="changeDay(-1)" aria-label="Previous day">
                    <i class="bi bi-chevron-left fs-5"></i>
                </button>
                <div class="day-nav-center">
                    <p class="day-nav-label fs-5" id="dayLabel">Loading…</p>
                    <p class="day-nav-date fw-medium" id="dayDate"></p>
                </div>
                <button class="day-nav-btn shadow-sm" id="nextDayBtn" onclick="changeDay(1)" aria-label="Next day">
                    <i class="bi bi-chevron-right fs-5"></i>
                </button>
            </div>

            <div class="day-tabs-strip mb-4 pb-2 overflow-auto" id="dayTabsStrip" style="flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none;">
                @for (int d = 0; d < slotsByDay.Count; d++)
                {
                    var day = slotsByDay[d];
                    var isToday = day.Key.Date == DateTime.Today;
                    var isTomorrow = day.Key.Date == DateTime.Today.AddDays(1);
                    var label = isToday ? "Today" : isTomorrow ? "Tomorrow" : day.Key.ToString("ddd");
                    <button class="day-tab px-4 py-3 shadow-sm border" data-day-index="@d" onclick="selectDay(@d)" style="min-width: 120px;">
                        <span class="day-tab-label text-primary">@label</span>
                        <span class="day-tab-date fs-5 mt-1">@day.Key.ToString("MMM d")</span>
                        <span class="day-tab-count badge bg-surface-soft text-muted border mt-2">@day.Count() slots</span>
                    </button>
                }
            </div>

            @for (int d = 0; d < slotsByDay.Count; d++)
            {
                var dayGroup = slotsByDay[d];
                <div class="day-slots-panel" id="dayPanel_@d" style="display:none;">
                    <div class="row g-3">
                        @foreach (var slot in dayGroup.OrderBy(s => s.StartTime))
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="slot-row bg-surface border shadow-sm rounded-4 h-100 flex-column align-items-start p-4 hover-lift">
                                    <div class="d-flex w-100 justify-content-between align-items-center border-bottom pb-3 mb-3">
                                        <div class="slot-time-block fs-5 text-primary">
                                            <i class="bi bi-clock-history slot-clock-icon"></i>
                                            <span class="slot-time-text">
                                                @slot.StartTime.ToString(@"hh\:mm") <span class="slot-time-sep text-muted mx-1">–</span> @slot.EndTime.ToString(@"hh\:mm")
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <div class="slot-clinic-block fs-6 mb-4 fw-medium text-body">
                                        <i class="bi bi-hospital text-info fs-5"></i>
                                        <span class="slot-clinic-text">@(slot.ClinicName ?? $"Clinic {slot.ClinicId}")</span>
                                    </div>
                                    
                                    <div class="slot-action-block w-100 mt-auto">
                                        @if (isPatient)
                                        {
                                            <form asp-controller="Appointment" asp-action="Book" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="DoctorId" value="@Model.Id" />
                                                <input type="hidden" name="AppointmentDate" value="@(dayGroup.Key.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="StartTime" value="@slot.StartTime" />
                                                <input type="hidden" name="EndTime" value="@slot.EndTime" />
                                                <input type="hidden" name="ClinicId" value="@slot.ClinicId" />
                                                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">
                                                    <i class="bi bi-calendar-check me-2"></i> Book Appointment
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="bg-surface-soft border rounded-3 p-2 text-center text-muted fw-medium w-100">
                                                Sign in as patient to book
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state border-0 bg-surface-soft py-5 rounded-4 mt-4">
                <i class="bi bi-calendar-x text-muted opacity-25" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mt-3 text-body">No available slots</h5>
                <p class="text-muted mb-0">Check back later or browse another doctor.</p>
            </div>
        }
    </div>

    <script>
        (function () {
            var totalDays = @slotsByDay.Count;
            var currentDay = 0;

            var days = [];
            @for (int d = 0; d < slotsByDay.Count; d++)
            {
                var day = slotsByDay[d];
                var isToday = day.Key.Date == DateTime.Today;
                var isTomorrow = day.Key.Date == DateTime.Today.AddDays(1);
                var label = isToday ? "Today" : isTomorrow ? "Tomorrow" : day.Key.ToString("dddd");
                var dateStr = day.Key.ToString("MMMM d, yyyy");
                <text>days.push({ label: "@label", date: "@dateStr", count: @day.Count() });</text>
            }

            function selectDay(index) {
                if (index < 0 || index >= totalDays) return;

                // hide all panels
                document.querySelectorAll('.day-slots-panel').forEach(function(p) { p.style.display = 'none'; });
                // deactivate all tabs
                document.querySelectorAll('.day-tab').forEach(function(t) { 
                    t.classList.remove('active', 'bg-primary', 'text-white', 'border-primary'); 
                    var countBadge = t.querySelector('.day-tab-count');
                    var labelBadge = t.querySelector('.day-tab-label');
                    if (countBadge) {
                        countBadge.classList.remove('bg-white', 'text-primary');
                        countBadge.classList.add('bg-surface-soft', 'text-muted');
                    }
                    if(labelBadge) labelBadge.classList.add('text-primary');
                });

                currentDay = index;

                // show selected panel
                var panel = document.getElementById('dayPanel_' + index);
                if (panel) panel.style.display = 'block';

                // activate tab
                var tab = document.querySelector('[data-day-index="' + index + '"]');
                if (tab) {
                    tab.classList.add('active', 'bg-primary', 'text-white', 'border-primary');
                    var countBadge = tab.querySelector('.day-tab-count');
                    var labelBadge = tab.querySelector('.day-tab-label');
                    if (countBadge) {
                        countBadge.classList.remove('bg-surface-soft', 'text-muted');
                        countBadge.classList.add('bg-white', 'text-primary');
                    }
                    if(labelBadge) labelBadge.classList.remove('text-primary');
                }

                // update navigator
                var d = days[index];
                document.getElementById('dayLabel').textContent = d.label + ' · ' + d.count + ' slot' + (d.count !== 1 ? 's' : '');
                document.getElementById('dayDate').textContent = d.date;

                document.getElementById('prevDayBtn').disabled = index === 0;
                document.getElementById('nextDayBtn').disabled = index === totalDays - 1;
            }

            window.changeDay = function(delta) { selectDay(currentDay + delta); };
            window.selectDay = selectDay;

            if (totalDays > 0) selectDay(0);
        })();
    </script>

    <div class="section-card p-4 animate-in stagger-3">
        <div class="d-flex align-items-center gap-3 border-bottom pb-4 mb-4">
            <div class="bg-primary-soft text-primary p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                <i class="bi bi-star-fill fs-4"></i>
            </div>
            <div>
                <h3 class="fw-bold mb-0">Patient Reviews</h3>
                <p class="text-muted mb-0">Real feedback from verified appointments</p>
            </div>
        </div>

        <div style="max-height: 400px; overflow-y: auto; padding-right: 12px; scrollbar-width: thin;">
            @if (Model.Reviews.Any())
            {
                <div class="d-grid gap-3">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card bg-surface border shadow-sm p-4 hover-lift">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="rating-stars mb-0" style="font-size: 1.1rem; color: var(--warning)">
                                    @for(int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rating)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-muted opacity-25"></i>
                                        }
                                    }
                                </div>
                                <span class="badge bg-surface-soft text-muted border px-2 py-1"><i class="bi bi-calendar2 me-1"></i> @review.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            <p class="text-body fs-6 mb-0 lh-lg">"@review.Comment"</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state border-0 py-5">
                    <i class="bi bi-chat-square-text text-muted opacity-25" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold mt-3 text-body">No reviews yet</h5>
                    <p class="text-muted mb-0">Patients will be able to leave reviews after their completed appointments.</p>
                </div>
            }
        </div>
    </div>
</div>
