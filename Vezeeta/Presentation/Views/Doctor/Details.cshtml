@model Application.DTOs.Doctors.DoctorDetailsDto

@{
    ViewData["Title"] = "Doctor Details";
    var availableSlots =
        ViewBag.AvailableSlots as IEnumerable<Application.DTOs.Appointments.AvailableSlotDto>
        ?? Enumerable.Empty<Application.DTOs.Appointments.AvailableSlotDto>();
    var appointments =
        ViewBag.Appointments as IEnumerable<Domain.Entities.Appointment>
        ?? Enumerable.Empty<Domain.Entities.Appointment>();
    var isPatient = User.IsInRole("Patient") || User.IsInRole("patient");
    var canManageDoctor =
        User.IsInRole("Admin")
        || User.IsInRole("admin")
        || User.IsInRole("Doctor")
        || User.IsInRole("doctor");
    var availabilityButtonClass =
        Model.IsAvailable
            ? "btn-outline-danger"
            : "btn-outline-success";
    var availabilityButtonText =
        Model.IsAvailable
            ? "Mark Unavailable"
            : "Mark Available";
}

<div class="container mt-5">

    <!-- TOP CARD -->

    <div class="card shadow-lg border-0 rounded-4 mb-5">

        <div class="card-body p-5">

            <div class="row align-items-center">

                <!-- IMAGE -->

                <div class="col-md-3 text-center">

                    <img src="~/images/@Model.ProfilePicture"
                        alt="Dr. @Model.FullName"
                         class="rounded-circle shadow"
                         width="200"
                         height="200"
                         style="object-fit:cover;" />

                </div>

                <!-- INFO -->

                <div class="col-md-9">

                    <h1 class="fw-bold">
                        Dr. @Model.FullName
                    </h1>

                    <span class="badge bg-primary fs-6 mb-3">
                        @Model.Specialization
                    </span>

                    <p class="text-muted">
                        @Model.YearsOfExperience Years Experience
                    </p>

                    <p>
                        @Model.Bio
                    </p>

                    <p>
                        <strong>Qualification:</strong>
                        @Model.Qualification
                    </p>

                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success fs-6">
                            Available
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">
                            Not Available
                        </span>
                    }

                </div>

            </div>

        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (canManageDoctor)
    {
        <!-- DOCTOR ACTIONS -->
        <div class="card shadow border-0 rounded-4 mb-5">
            <div class="card-header bg-primary text-white p-3">
                <h3 class="mb-0">
                    Doctor Actions
                </h3>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Dashboard"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary">
                        Dashboard
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-warning">
                        Edit Profile
                    </a>

                    <a asp-action="Schedules"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-primary">
                        Manage Schedules
                    </a>

                    <a asp-action="AddSchedule"
                       asp-route-doctorId="@Model.Id"
                       class="btn btn-outline-success">
                        Add Schedule
                    </a>

                    <a asp-action="AssignClinic"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">
                        Assign Clinic
                    </a>

                    <a asp-controller="Review"
                       asp-action="DoctorReviews"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-dark">
                        Reviews
                    </a>

                    <a asp-controller="Payment"
                       asp-action="DoctorPayments"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-info">
                        Payments
                    </a>

                    <form asp-action="ToggleAvailability" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="isAvailable" value="@(!Model.IsAvailable)" />
                        <button type="submit"
                                class="btn @availabilityButtonClass">
                            @availabilityButtonText
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- BOOKED APPOINTMENTS -->
        <div class="card shadow border-0 rounded-4 mb-5">
            <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-1">Booked Appointments</h5>
                    <p class="text-muted mb-0 small">Patient appointments and scheduling details.</p>
                </div>
                <span class="badge bg-primary rounded-pill fs-6 px-3 py-2">
                    @appointments.Count() appointments
                </span>
            </div>

            <div class="card-body p-4">
                @if (appointments.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var appt in appointments.OrderByDescending(a => a.AppointmentDate))
                        {
                            var statusClass = appt.Status == Domain.Enums.AppointmentStatus.Confirmed
                                ? "status-success"
                                : appt.Status == Domain.Enums.AppointmentStatus.Pending ? "status-warning" 
                                : appt.Status == Domain.Enums.AppointmentStatus.Completed ? "status-info" : "status-muted";

                            <article class="appointment-card card p-4 border-0 shadow-sm hover-lift">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@ProfilePictureHelper.GetUrl(appt.Patient?.ApplicationUser?.ProfilePicture, appt.Patient?.ApplicationUser?.FullName, size: 80)"
                                             alt="@(appt.Patient?.ApplicationUser?.FullName ?? "Patient")"
                                             class="rounded-circle border border-2 border-primary"
                                             width="48"
                                             height="48"
                                             style="object-fit:cover;" />
                                        <div>
                                            <h6 class="fw-bold mb-1">@(appt.Patient?.ApplicationUser?.FullName ?? "N/A")</h6>
                                            <small class="text-muted">@appt.AppointmentDate.ToString("dd MMM yyyy"), @appt.StartTime.ToString(@"hh\:mm")</small>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="text-end">
                                            <span class="d-block small text-muted">@(appt.Clinic?.Name ?? "-")</span>
                                            <span class="d-block small fw-semibold">@appt.EndTime.ToString(@"hh\:mm")</span>
                                        </div>
                                        <span class="status-badge @statusClass">@appt.Status</span>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state text-center py-5">
                        <i class="bi bi-calendar-x" style="font-size: 2.5rem; color: #ddd;"></i>
                        <p class="mt-3 text-muted mb-0">No appointments booked yet.</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- AVAILABLE APPOINTMENTS -->

    <div class="card shadow border-0 rounded-4 mb-5 overflow-hidden reservation-section">

        <div class="card-header reservation-section-header text-white p-4 border-0">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">

                <div>
                    <p class="text-uppercase small mb-1 reservation-eyebrow">
                        Appointment booking
                    </p>
                    <h3 class="mb-1">
                        Available Appointment Slots
                    </h3>
                    <p class="mb-0 reservation-subtitle">
                        Choose a time that fits your schedule and reserve your visit in seconds.
                    </p>
                </div>

                <div class="reservation-count-badge">
                    @availableSlots.Count() slots
                </div>

            </div>

        </div>

        <div class="card-body p-4 p-lg-5 reservation-section-body">

            @if (availableSlots.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">

                    @foreach (var slot in availableSlots.Select((s, i) => new { Slot = s, Index = i + 1 }))
                    {
                        var colorVariant = slot.Index % 4;

                        <div class="col">

                            <div class="card h-100 border-0 shadow-sm reservation-slot-card reservation-slot-@colorVariant">

                                <div class="card-body d-flex flex-column p-4">

                                    <div class="d-flex justify-content-between align-items-start mb-4">
                                        <span class="badge reservation-slot-badge reservation-badge-@colorVariant rounded-pill">
                                            ★ Slot @slot.Index
                                        </span>
                                        <span class="clinic-badge">@slot.Slot.ClinicId</span>
                                    </div>

                                    <h5 class="reservation-slot-date fw-bold mb-1">
                                        @slot.Slot.Date.ToString("dddd, MMM dd")
                                    </h5>

                                    <div class="reservation-slot-time mb-4">
                                        <span class="time-badge">
                                            @slot.Slot.StartTime.ToString(@"hh\:mm") - @slot.Slot.EndTime.ToString(@"hh\:mm")
                                        </span>
                                    </div>

                                    <p class="text-muted mb-4 small" style="flex: 1;">
                                        Select this slot to continue with your appointment booking.
                                    </p>

                                    <div class="mt-auto">
                                        @if (isPatient)
                                        {
                                            <form asp-controller="Appointment" asp-action="Book" method="post" class="d-grid">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="DoctorId" value="@Model.Id" />
                                                <input type="hidden" name="AppointmentDate" value="@(slot.Slot.Date.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="StartTime" value="@slot.Slot.StartTime" />
                                                <input type="hidden" name="EndTime" value="@slot.Slot.EndTime" />
                                                <input type="hidden" name="ClinicId" value="@slot.Slot.ClinicId" />

                                                <button class="btn btn-slot btn-lg reservation-book-btn reservation-btn-@colorVariant">
                                                    <i class="bi bi-calendar-check"></i> Book Now
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="alert alert-light border mb-0 small text-center reservation-login-note">
                                                Login as a patient to reserve this slot.
                                            </div>
                                        }
                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }
            else
            {
                <div class="reservation-empty-state text-center p-5">
                    <div class="reservation-empty-icon mb-3">•</div>
                    <h4 class="mb-2">No available appointments right now</h4>
                    <p class="text-muted mb-0">
                        Check back later or browse another doctor if you need an earlier opening.
                    </p>
                </div>
            }

        </div>

    </div>

    <!-- REVIEWS -->

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-dark text-white p-3">

            <h3 class="mb-0">
                Reviews
            </h3>

        </div>

        <div class="card-body">

            <div style="max-height: 280px; overflow-y: auto; padding-right: 6px;">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card mb-3 shadow-sm">

                            <div class="card-body">

                                <h5>
                                    Rating: @review.Rating ⭐
                                </h5>

                                <p>
                                    @review.Comment
                                </p>

                                <small class="text-muted">
                                    @review.CreatedAt
                                </small>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        No reviews yet.
                    </div>
                }
            </div>

        </div>

    </div>

</div>
