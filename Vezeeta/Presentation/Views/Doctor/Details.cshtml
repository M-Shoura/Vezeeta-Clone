    <!-- AVAILABLE APPOINTMENTS -->

    @{
        var slotsByDay = availableSlots
            .GroupBy(s => s.Date.Date)
            .OrderBy(g => g.Key)
            .ToList();
    }

    <div class="slots-section mb-5">

        <!-- Section header -->
        <div class="slots-header mb-4">
            <div>
                <p class="slots-eyebrow">Appointment Booking</p>
                <h3 class="slots-title">Available Slots</h3>
            </div>
            <span class="slots-total-badge">@availableSlots.Count() available</span>
        </div>

        @if (slotsByDay.Any())
        {
            <!-- Day Navigator -->
            <div class="day-navigator mb-4" id="dayNavigator">

                <button class="day-nav-btn" id="prevDayBtn" onclick="changeDay(-1)" aria-label="Previous day">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="day-nav-center">
                    <p class="day-nav-label" id="dayLabel">Loading…</p>
                    <p class="day-nav-date" id="dayDate"></p>
                </div>

                <button class="day-nav-btn" id="nextDayBtn" onclick="changeDay(1)" aria-label="Next day">
                    <i class="bi bi-chevron-right"></i>
                </button>

            </div>

            <!-- Day Tabs (hidden pills for desktop) -->
            <div class="day-tabs-strip mb-4" id="dayTabsStrip">
                @for (int d = 0; d < slotsByDay.Count; d++)
                {
                    var day = slotsByDay[d];
                    var isToday = day.Key.Date == DateTime.Today;
                    var isTomorrow = day.Key.Date == DateTime.Today.AddDays(1);
                    var label = isToday ? "Today" : isTomorrow ? "Tomorrow" : day.Key.ToString("ddd");
                    <button class="day-tab" data-day-index="@d" onclick="selectDay(@d)">
                        <span class="day-tab-label">@label</span>
                        <span class="day-tab-date">@day.Key.ToString("MMM d")</span>
                        <span class="day-tab-count">@day.Count()</span>
                    </button>
                }
            </div>

            <!-- Slot panels per day -->
            @for (int d = 0; d < slotsByDay.Count; d++)
            {
                var dayGroup = slotsByDay[d];
                <div class="day-slots-panel" id="dayPanel_@d" style="display:none;">
                    <div class="slots-grid">
                        @foreach (var slot in dayGroup.OrderBy(s => s.StartTime))
                        {
                            <div class="slot-row">
                                <div class="slot-time-block">
                                    <i class="bi bi-clock slot-clock-icon"></i>
                                    <span class="slot-time-text">
                                        @slot.StartTime.ToString(@"hh\:mm") <span class="slot-time-sep">–</span> @slot.EndTime.ToString(@"hh\:mm")
                                    </span>
                                </div>
                                <div class="slot-clinic-block">
                                    <i class="bi bi-building slot-clinic-icon"></i>
                                    <span class="slot-clinic-text">@(slot.ClinicName ?? $"Clinic {slot.ClinicId}")</span>
                                </div>
                                <div class="slot-action-block">
                                    @if (isPatient)
                                    {
                                        <form asp-controller="Appointment" asp-action="Book" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="DoctorId" value="@Model.Id" />
                                            <input type="hidden" name="AppointmentDate" value="@(dayGroup.Key.ToString("yyyy-MM-dd"))" />
                                            <input type="hidden" name="StartTime" value="@slot.StartTime" />
                                            <input type="hidden" name="EndTime" value="@slot.EndTime" />
                                            <input type="hidden" name="ClinicId" value="@slot.ClinicId" />
                                            <button type="submit" class="slot-book-btn">
                                                <i class="bi bi-calendar-check"></i> Book
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="slot-login-note">Sign in to book</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="slots-empty">
                <i class="bi bi-calendar-x slots-empty-icon"></i>
                <h5 class="mt-3 mb-1">No available slots</h5>
                <p class="text-muted mb-0">Check back later or browse another doctor.</p>
            </div>
        }

    </div>

    <script>
        (function () {
            var totalDays = @slotsByDay.Count;
            var currentDay = 0;

            var days = [];
            @for (int d = 0; d < slotsByDay.Count; d++)
            {
                var day = slotsByDay[d];
                var isToday = day.Key.Date == DateTime.Today;
                var isTomorrow = day.Key.Date == DateTime.Today.AddDays(1);
                var label = isToday ? "Today" : isTomorrow ? "Tomorrow" : day.Key.ToString("dddd");
                var dateStr = day.Key.ToString("MMMM d, yyyy");
                <text>days.push({ label: "@label", date: "@dateStr", count: @day.Count() });</text>
            }

            function selectDay(index) {
                if (index < 0 || index >= totalDays) return;

                // hide all panels
                document.querySelectorAll('.day-slots-panel').forEach(function(p) { p.style.display = 'none'; });
                // deactivate all tabs
                document.querySelectorAll('.day-tab').forEach(function(t) { t.classList.remove('active'); });

                currentDay = index;

                // show selected panel
                var panel = document.getElementById('dayPanel_' + index);
                if (panel) panel.style.display = 'block';

                // activate tab
                var tab = document.querySelector('[data-day-index="' + index + '"]');
                if (tab) tab.classList.add('active');

                // update navigator
                var d = days[index];
                document.getElementById('dayLabel').textContent = d.label + ' · ' + d.count + ' slot' + (d.count !== 1 ? 's' : '');
                document.getElementById('dayDate').textContent = d.date;

                document.getElementById('prevDayBtn').disabled = index === 0;
                document.getElementById('nextDayBtn').disabled = index === totalDays - 1;
            }

            window.changeDay = function(delta) { selectDay(currentDay + delta); };
            window.selectDay = selectDay;

            if (totalDays > 0) selectDay(0);
        })();
    </script>

    <!-- REVIEWS -->

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-dark text-white p-3">

            <h3 class="mb-0">
                Reviews
            </h3>

        </div>

        <div class="card-body">

            <div style="max-height: 280px; overflow-y: auto; padding-right: 6px;">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card mb-3 shadow-sm">

                            <div class="card-body">

                                <h5>
                                    Rating: @review.Rating ⭐
                                </h5>

                                <p>
                                    @review.Comment
                                </p>

                                <small class="text-muted">
                                    @review.CreatedAt
                                </small>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        No reviews yet.
                    </div>
                }
            </div>

        </div>

    </div>

</div>
