@model Application.DTOs.Doctors.DoctorDetailsDto

@{
    ViewData["Title"] = "Doctor Details";
    var availableSlots =
        ViewBag.AvailableSlots as IEnumerable<Application.DTOs.Appointments.AvailableSlotDto>
        ?? Enumerable.Empty<Application.DTOs.Appointments.AvailableSlotDto>();
    var appointments =
        ViewBag.Appointments as IEnumerable<Domain.Entities.Appointment>
        ?? Enumerable.Empty<Domain.Entities.Appointment>();
    var isPatient = User.IsInRole("Patient") || User.IsInRole("patient");
    var canManageDoctor =
        User.IsInRole("Admin")
        || User.IsInRole("admin")
        || User.IsInRole("Doctor")
        || User.IsInRole("doctor");
    var availabilityButtonClass =
        Model.IsAvailable
            ? "btn-outline-danger"
            : "btn-outline-success";
    var availabilityButtonText =
        Model.IsAvailable
            ? "Mark Unavailable"
            : "Mark Available";
}

<div class="container mt-5">

    <!-- TOP CARD -->

    <div class="card shadow-lg border-0 rounded-4 mb-5">

        <div class="card-body p-5">

            <div class="row align-items-center">

                <!-- IMAGE -->

                <div class="col-md-3 text-center">

                    <img src="~/images/@Model.ProfilePicture"
                        alt="Dr. @Model.FullName"
                         class="rounded-circle shadow"
                         width="200"
                         height="200"
                         style="object-fit:cover;" />

                </div>

                <!-- INFO -->

                <div class="col-md-9">

                    <h1 class="fw-bold">
                        Dr. @Model.FullName
                    </h1>

                    <span class="badge bg-primary fs-6 mb-3">
                        @Model.Specialization
                    </span>

                    <p class="text-muted">
                        @Model.YearsOfExperience Years Experience
                    </p>

                    <p>
                        @Model.Bio
                    </p>

                    <p>
                        <strong>Qualification:</strong>
                        @Model.Qualification
                    </p>

                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success fs-6">
                            Available
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">
                            Not Available
                        </span>
                    }

                </div>

            </div>

        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (canManageDoctor)
    {
        <!-- DOCTOR ACTIONS -->
        <div class="card shadow border-0 rounded-4 mb-5">
            <div class="card-header bg-primary text-white p-3">
                <h3 class="mb-0">
                    Doctor Actions
                </h3>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Dashboard"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary">
                        Dashboard
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-warning">
                        Edit Profile
                    </a>

                    <a asp-action="Schedules"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-primary">
                        Manage Schedules
                    </a>

                    <a asp-action="AddSchedule"
                       asp-route-doctorId="@Model.Id"
                       class="btn btn-outline-success">
                        Add Schedule
                    </a>

                    <a asp-action="AssignClinic"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">
                        Assign Clinic
                    </a>

                    <a asp-controller="Review"
                       asp-action="DoctorReviews"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-dark">
                        Reviews
                    </a>

                    <a asp-controller="Payment"
                       asp-action="DoctorPayments"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-info">
                        Payments
                    </a>

                    <form asp-action="ToggleAvailability" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="isAvailable" value="@(!Model.IsAvailable)" />
                        <button type="submit"
                                class="btn @availabilityButtonClass">
                            @availabilityButtonText
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- BOOKED APPOINTMENTS -->
        <div class="card shadow border-0 rounded-4 mb-5">
            <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    Appointments
                </h3>
                <span class="badge bg-primary rounded-pill">
                    @appointments.Count()
                </span>
            </div>

            <div class="card-body p-0">
                @if (appointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Patient</th>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Clinic</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in appointments.OrderByDescending(a => a.AppointmentDate))
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="@ProfilePictureHelper.GetUrl(appt.Patient?.ApplicationUser?.ProfilePicture, appt.Patient?.ApplicationUser?.FullName, size: 80)"
                                                       alt="@(appt.Patient?.ApplicationUser?.FullName ?? "Patient")"
                                                     class="rounded-circle"
                                                     width="38"
                                                     height="38"
                                                     style="object-fit:cover;" />
                                                <span class="fw-semibold">
                                                    @(appt.Patient?.ApplicationUser?.FullName ?? "N/A")
                                                </span>
                                            </div>
                                        </td>
                                        <td>@appt.AppointmentDate.ToString("MMM dd, yyyy")</td>
                                        <td>@appt.StartTime.ToString(@"hh\:mm") - @appt.EndTime.ToString(@"hh\:mm")</td>
                                        <td>@(appt.Clinic?.Name ?? "-")</td>
                                        <td>
                                            @switch (appt.Status)
                                            {
                                                case Domain.Enums.AppointmentStatus.Pending:
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                    break;
                                                case Domain.Enums.AppointmentStatus.Confirmed:
                                                    <span class="badge bg-success">Confirmed</span>
                                                    break;
                                                case Domain.Enums.AppointmentStatus.Completed:
                                                    <span class="badge bg-info text-dark">Completed</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@appt.Status</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        No appointments yet.
                    </div>
                }
            </div>
        </div>
    }

    <!-- AVAILABLE APPOINTMENTS -->

    <div class="card shadow border-0 rounded-4 mb-5 overflow-hidden reservation-section">

        <div class="card-header reservation-section-header text-white p-4 border-0">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">

                <div>
                    <p class="text-uppercase small mb-1 reservation-eyebrow">
                        Appointment booking
                    </p>
                    <h3 class="mb-1">
                        Available Appointment Slots
                    </h3>
                    <p class="mb-0 reservation-subtitle">
                        Choose a time that fits your schedule and reserve your visit in seconds.
                    </p>
                </div>

                <div class="reservation-count-badge">
                    @availableSlots.Count() slots
                </div>

            </div>

        </div>

        <div class="card-body p-4 p-lg-5 reservation-section-body">

            @if (availableSlots.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">

                    @foreach (var slot in availableSlots)
                    {
                        <div class="col">

                            <div class="card h-100 border-0 shadow-sm reservation-slot-card">

                                <div class="card-body d-flex flex-column p-4">

                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <span class="badge reservation-slot-badge rounded-pill">
                                            Available
                                        </span>
                                        <span class="text-muted small">
                                            Slot @slot.ClinicId
                                        </span>
                                    </div>

                                    <h5 class="mb-2 reservation-slot-date">
                                        @slot.Date.ToString("dddd, MMM dd")
                                    </h5>

                                    <div class="reservation-slot-time mb-2">
                                        @slot.StartTime.ToString(@"hh\:mm")
                                        <span class="mx-2 text-muted">-</span>
                                        @slot.EndTime.ToString(@"hh\:mm")
                                    </div>

                                    <p class="text-muted mb-4 small">
                                        Select this slot to continue with your appointment booking.
                                    </p>

                                    <div class="mt-auto">
                                        @if (isPatient)
                                        {
                                            <form asp-controller="Appointment" asp-action="Book" method="post" class="d-grid">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="DoctorId" value="@Model.Id" />
                                                <input type="hidden" name="AppointmentDate" value="@(slot.Date.ToString("yyyy-MM-dd"))" />
                                                <input type="hidden" name="StartTime" value="@slot.StartTime" />
                                                <input type="hidden" name="EndTime" value="@slot.EndTime" />
                                                <input type="hidden" name="ClinicId" value="@slot.ClinicId" />

                                                <button class="btn btn-slot btn-lg reservation-book-btn">
                                                    Book Appointment
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="alert alert-light border mb-0 small text-center reservation-login-note">
                                                Login as a patient to reserve this slot.
                                            </div>
                                        }
                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }
            else
            {
                <div class="reservation-empty-state text-center p-5">
                    <div class="reservation-empty-icon mb-3">•</div>
                    <h4 class="mb-2">No available appointments right now</h4>
                    <p class="text-muted mb-0">
                        Check back later or browse another doctor if you need an earlier opening.
                    </p>
                </div>
            }

        </div>

    </div>

    <!-- REVIEWS -->

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-dark text-white p-3">

            <h3 class="mb-0">
                Reviews
            </h3>

        </div>

        <div class="card-body">

            <div style="max-height: 280px; overflow-y: auto; padding-right: 6px;">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="card mb-3 shadow-sm">

                            <div class="card-body">

                                <h5>
                                    Rating: @review.Rating ⭐
                                </h5>

                                <p>
                                    @review.Comment
                                </p>

                                <small class="text-muted">
                                    @review.CreatedAt
                                </small>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        No reviews yet.
                    </div>
                }
            </div>

        </div>

    </div>

</div>
