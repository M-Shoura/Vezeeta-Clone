@model Domain.Entities.DoctorSchedule

@{
    ViewData["Title"] = "Delete Schedule";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" class="text-decoration-none">Doctors</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Schedules" asp-route-id="@Model.DoctorId" class="text-decoration-none">Schedules</a>
                    </li>
                    <li class="breadcrumb-item active">Delete</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-header bg-danger text-white p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div style="font-size:2rem;">🗑️</div>
                        <div>
                            <h4 class="mb-0 fw-bold">Delete Schedule</h4>
                            <small class="opacity-75">This action cannot be undone</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">

                    <div class="alert alert-warning rounded-3 mb-4">
                        <strong>⚠️ Are you sure</strong> you want to delete this schedule?
                    </div>

                    <!-- SCHEDULE DETAILS -->
                    <div class="rounded-3 bg-light p-4 mb-4">
                        <div class="row g-3">
                            <div class="col-sm-4 text-center">
                                <div class="text-muted small mb-1">Day</div>
                                <div class="fw-bold fs-5">@Model.Day</div>
                            </div>
                            <div class="col-sm-4 text-center border-start border-end">
                                <div class="text-muted small mb-1">Start Time</div>
                                <div class="fw-bold fs-5">@Model.StartTime.ToString(@"hh\:mm")</div>
                            </div>
                            <div class="col-sm-4 text-center">
                                <div class="text-muted small mb-1">End Time</div>
                                <div class="fw-bold fs-5">@Model.EndTime.ToString(@"hh\:mm")</div>
                            </div>
                        </div>
                        @if (Model.Clinic != null)
                        {
                            <hr />
                            <div class="text-center">
                                <span class="text-muted small">Clinic:</span>
                                <span class="fw-semibold ms-1">@Model.Clinic.Name</span>
                            </div>
                        }
                        <div class="text-center mt-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">
                                ⏱️ @Model.SlotDurationMinutes min slots
                            </span>
                        </div>
                    </div>

                    <form asp-action="DeleteSchedule" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-3">
                            <button type="submit"
                                    class="btn btn-danger btn-lg px-5 fw-semibold rounded-3">
                                🗑️ Yes, Delete
                            </button>
                            <a asp-action="Schedules"
                               asp-route-id="@Model.DoctorId"
                               class="btn btn-outline-secondary btn-lg px-4 rounded-3">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>