@model Application.DTOs.Dashboards.DoctorDashboardViewModel

@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="app-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="hero-panel p-4 p-xl-5 mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, "ffffff", "2563eb", 120)"
                         class="avatar-lg border border-3 border-white" alt="Dr. @Model.FullName" />
                    <div>
                        <span class="eyebrow text-white-50">Care workspace</span>
                        <h1 class="h2 fw-bold mb-1">Dr. @Model.FullName</h1>
                        <p class="mb-0 text-white-50">@Model.Specialization • @Model.YearsOfExperience years experience</p>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-light">
                        <i class="bi bi-pencil-square"></i> Edit Profile
                    </a>
                    <a asp-action="AddSchedule" asp-route-doctorId="@Model.DoctorId" class="btn btn-warning">
                        <i class="bi bi-calendar-plus"></i> Add Schedule
                    </a>
                    <a asp-action="AssignClinic" asp-route-id="@Model.DoctorId" class="btn btn-outline-light">
                        <i class="bi bi-hospital"></i> Add Clinic
                    </a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="glass-panel p-3">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <small class="text-white-50 fw-bold">Availability</small>
                            <div class="h3 fw-bold mb-0">@(Model.IsAvailable ? "Accepting visits" : "Unavailable")</div>
                        </div>
                        <span class="status-badge @(Model.IsAvailable ? "status-success" : "status-danger")">
                            @(Model.IsAvailable ? "Online" : "Offline")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Today's Appointments</p>
                <h2 class="metric-value">@Model.TodaysAppointmentsCount</h2>
                <span class="metric-trend">Scheduled for @DateTime.Today.ToString("dd MMM")</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Total Patients</p>
                <h2 class="metric-value">@Model.TotalPatients</h2>
                <span class="metric-trend">Unique patient records</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Pending Requests</p>
                <h2 class="metric-value">@Model.PendingRequests</h2>
                <span class="metric-trend">Needs confirmation</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Earnings</p>
                <h2 class="metric-value">EGP @Model.Earnings.ToString("N0")</h2>
                <span class="metric-trend">@Model.CompletedSessions completed sessions</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="section-card p-4 mb-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">Today's Queue</h5>
                        <p class="text-muted mb-0">Real appointments ordered by visit time.</p>
                    </div>
                </div>

                @if (Model.TodaysAppointments.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var appointment in Model.TodaysAppointments)
                        {
                            <article class="appointment-card card p-3">
                                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                                    <div>
                                        <h6 class="fw-bold mb-1">@appointment.PatientName</h6>
                                        <small class="text-muted">@appointment.ClinicName • @appointment.StartTime.ToString(@"hh\:mm") - @appointment.EndTime.ToString(@"hh\:mm")</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="status-badge @(appointment.Status == Domain.Enums.AppointmentStatus.Confirmed ? "status-success" : appointment.Status == Domain.Enums.AppointmentStatus.Pending ? "status-warning" : "status-muted")">
                                            @appointment.Status
                                        </span>
                                        @if (appointment.Status == Domain.Enums.AppointmentStatus.Confirmed || appointment.Status == Domain.Enums.AppointmentStatus.Completed)
                                        {
                                            if (appointment.HasPrescription && appointment.PrescriptionId.HasValue)
                                            {
                                                <a asp-controller="Prescription" asp-action="Edit" asp-route-id="@appointment.PrescriptionId" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil-square"></i> Edit Prescription
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-controller="Prescription" asp-action="Create" asp-route-appointmentId="@appointment.Id" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-prescription2"></i> Add Prescription
                                                </a>
                                            }
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-heart"></i>
                        <p class="mt-2 mb-0">No appointments scheduled for today.</p>
                    </div>
                }
            </div>

            <div class="section-card p-4">
                <h5 class="fw-bold mb-3">Upcoming Schedule</h5>
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Clinic</th>
                            <th>Status</th>
                            <th class="text-end">Prescription</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UpcomingAppointments.Any())
                        {
                            foreach (var appointment in Model.UpcomingAppointments)
                            {
                                <tr>
                                    <td class="fw-semibold">@appointment.PatientName</td>
                                    <td>@appointment.AppointmentDate.ToString("dd MMM yyyy")</td>
                                    <td>@appointment.StartTime.ToString(@"hh\:mm") - @appointment.EndTime.ToString(@"hh\:mm")</td>
                                    <td>@appointment.ClinicName</td>
                                    <td><span class="status-badge status-muted">@appointment.Status</span></td>
                                    <td class="text-end">
                                        @if (appointment.Status == Domain.Enums.AppointmentStatus.Confirmed || appointment.Status == Domain.Enums.AppointmentStatus.Completed)
                                        {
                                            if (appointment.HasPrescription && appointment.PrescriptionId.HasValue)
                                            {
                                                <a asp-controller="Prescription" asp-action="Edit" asp-route-id="@appointment.PrescriptionId" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-controller="Prescription" asp-action="Create" asp-route-appointmentId="@appointment.Id" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-prescription2"></i> Add
                                                </a>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6"><div class="empty-state my-2">No upcoming appointments yet.</div></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="section-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Timetable</h5>
                    <a asp-action="Schedules" asp-route-id="@Model.DoctorId" class="btn btn-sm btn-outline-primary">Manage</a>
                </div>

                @if (Model.Schedules.Any())
                {
                    <div class="d-grid gap-2">
                        @foreach (var schedule in Model.Schedules)
                        {
                            <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-light">
                                <div>
                                    <div class="fw-bold">@schedule.Day</div>
                                    <small class="text-muted">@schedule.StartTime.ToString(@"hh\:mm") - @schedule.EndTime.ToString(@"hh\:mm")</small>
                                </div>
                                <span class="badge bg-primary-subtle text-primary">@schedule.SlotDurationMinutes min</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">No schedules set.</div>
                }
            </div>

            <div class="section-card p-4 mb-4">
                <h5 class="fw-bold mb-3">Clinics & Fees</h5>
                @if (Model.Clinics.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var clinic in Model.Clinics)
                        {
                            <form asp-action="UpdateConsultationFee" method="post" class="p-3 rounded-4 bg-light">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="doctorId" value="@Model.DoctorId" />
                                <input type="hidden" name="clinicId" value="@clinic.ClinicId" />
                                <div class="fw-bold mb-2">@clinic.ClinicName</div>
                                <div class="input-group">
                                    <span class="input-group-text">EGP</span>
                                    <input type="number" name="consultationFee" step="0.01" min="0" value="@clinic.ConsultationFee" class="form-control" />
                                    <button type="submit" class="btn btn-primary">Save</button>
                                </div>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">No clinics assigned.</div>
                }
            </div>

            <div class="section-card p-4">
                <h5 class="fw-bold mb-3">Notifications</h5>
                <div class="activity-item">
                    <span class="activity-dot"></span>
                    <div>
                        <div class="fw-bold">@Model.PendingRequests appointment requests</div>
                        <small class="text-muted">Review pending requests before clinic hours.</small>
                    </div>
                </div>
                <div class="activity-item">
                    <span class="activity-dot bg-success"></span>
                    <div>
                        <div class="fw-bold">@Model.UpcomingAppointmentsCount upcoming visits</div>
                        <small class="text-muted">Based on real scheduled appointments.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
