@{
    ViewData["Title"] = "Assign Clinic";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" class="text-decoration-none">Doctors</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Dashboard" asp-route-id="@ViewBag.DoctorId" class="text-decoration-none">Dashboard</a>
                    </li>
                    <li class="breadcrumb-item active">Assign Clinic</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="card-header p-4 text-white"
                     style="background: linear-gradient(135deg, #2e7d32, #1b5e20);">
                    <div class="d-flex align-items-center gap-3">
                        <div style="font-size:2rem;">🏥</div>
                        <div>
                            <h4 class="mb-0 fw-bold">Assign Clinic</h4>
                            <small class="opacity-75">Link a clinic and set consultation fee</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">

                    <form asp-action="AssignClinic" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="doctorId"
                               value="@ViewBag.DoctorId" />

                        <!-- CLINIC DROPDOWN -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-dark">
                                🏥 Select Clinic <span class="text-danger">*</span>
                            </label>
                            <select name="clinicId"
                                    class="form-select form-select-lg rounded-3"
                                    required>
                                <option value="">— Select a Clinic —</option>
                                @if (ViewBag.Clinics != null)
                                {
                                    @foreach (var item in (Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Clinics)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- CONSULTATION FEE -->
                        <div class="mb-5">
                            <label class="form-label fw-semibold text-dark">
                                💰 Consultation Fee <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light fw-semibold">EGP</span>
                                <input type="number"
                                       name="consultationFee"
                                       step="0.01"
                                       min="0"
                                       placeholder="e.g. 500.00"
                                       class="form-control rounded-end-3"
                                       required />
                            </div>
                            <div class="form-text mt-1">
                                This is the fee patients pay per appointment at this clinic.
                            </div>
                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex gap-3">
                            <button type="submit"
                                    class="btn btn-success btn-lg px-5 fw-semibold rounded-3">
                                ✅ Assign Clinic
                            </button>
                            <a asp-action="Dashboard"
                               asp-route-id="@ViewBag.DoctorId"
                               class="btn btn-outline-secondary btn-lg px-4 rounded-3">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>