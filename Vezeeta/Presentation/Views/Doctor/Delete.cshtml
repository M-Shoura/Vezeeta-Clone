@model Application.DTOs.Doctors.DoctorDto

@{
    ViewData["Title"] = "Delete Doctor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" class="text-decoration-none">Doctors</a>
                    </li>
                    <li class="breadcrumb-item active">Delete Doctor</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="card-header bg-danger text-white p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div style="font-size: 2rem;">⚠️</div>
                        <div>
                            <h4 class="mb-0 fw-bold">Delete Doctor</h4>
                            <small class="opacity-75">This action is permanent and cannot be undone</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">

                    <div class="alert alert-danger rounded-3 mb-4">
                        <strong>Are you sure</strong> you want to permanently delete this doctor profile?
                    </div>

                    <!-- DOCTOR PREVIEW -->
                    <div class="d-flex align-items-center gap-4 bg-light rounded-3 p-4 mb-5">
                        <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, "e74c3c", "fff", 80)"
                             class="rounded-circle shadow"
                             width="80" height="80"
                             style="object-fit: cover;" />
                        <div>
                            <h5 class="fw-bold mb-1">Dr. @Model.FullName</h5>
                            <span class="badge bg-primary bg-opacity-10 text-primary me-2">
                                @Model.Specialization
                            </span>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                @Model.YearsOfExperience yrs experience
                            </span>
                            @if (!string.IsNullOrEmpty(Model.Bio))
                            {
                                <p class="text-muted small mt-2 mb-0">@Model.Bio</p>
                            }
                        </div>
                    </div>

                    <!-- CONFIRM FORM -->
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="d-flex gap-3">
                            <button type="submit"
                                    class="btn btn-danger btn-lg px-5 fw-semibold rounded-3">
                                🗑️ Yes, Delete Permanently
                            </button>
                            <a asp-action="Index"
                               class="btn btn-outline-secondary btn-lg px-4 rounded-3">
                                Cancel
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
