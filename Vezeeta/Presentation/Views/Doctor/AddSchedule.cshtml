@model Presentation.ViewModels.CreateDoctorScheduleViewModel

@{
    ViewData["Title"] = "Add Schedule";
}

<div class="app-container" style="max-width: 800px; margin: 0 auto;">
    <div class="page-header animate-in border-bottom pb-3 mb-4">
        <a asp-action="Dashboard" asp-route-id="@Model.DoctorId" class="btn btn-sm btn-light text-muted mb-3 shadow-sm border fw-medium"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
        <h1 class="page-title"><i class="bi bi-calendar-plus me-2 text-warning"></i> Add Schedule</h1>
        <p class="page-subtitle">Define working hours and slot durations for a specific day.</p>
    </div>

    <div class="section-card p-4 p-md-5 animate-in stagger-1">
        <form asp-action="AddSchedule" method="post" id="scheduleForm" class="needs-validation">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DoctorId" />

            <div asp-validation-summary="All" class="alert alert-danger shadow-sm d-none" role="alert"></div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label class="form-label fw-bold">Clinic Assignment <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-hospital"></i></span>
                            <select asp-for="ClinicId" asp-items="ViewBag.Clinics" class="form-select border-start-0 ps-0 bg-light cursor-pointer">
                                <option value="">Select a Clinic</option>
                            </select>
                        </div>
                        <span asp-validation-for="ClinicId" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label class="form-label fw-bold">Day of Week <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-calendar-day"></i></span>
                            <select asp-for="Day" asp-items="Html.GetEnumSelectList<System.DayOfWeek>()" class="form-select border-start-0 ps-0 bg-light cursor-pointer">
                            </select>
                        </div>
                        <span asp-validation-for="Day" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label class="form-label fw-bold">Start Time <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-clock"></i></span>
                            <input asp-for="StartTime" type="time" class="form-control border-start-0 ps-0 bg-light cursor-pointer" />
                        </div>
                        <span asp-validation-for="StartTime" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label class="form-label fw-bold">End Time <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-clock-history"></i></span>
                            <input asp-for="EndTime" type="time" class="form-control border-start-0 ps-0 bg-light cursor-pointer" />
                        </div>
                        <span asp-validation-for="EndTime" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group position-relative p-4 bg-surface-soft border rounded-4 mt-2">
                        <label class="form-label fw-bold">Slot Duration <span class="text-danger">*</span></label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden" style="max-width: 200px;">
                                <input asp-for="SlotDurationMinutes" type="number" min="5" max="120" step="5" class="form-control border-end-0 fw-bold text-primary bg-white" />
                                <span class="input-group-text bg-white text-muted fw-medium border-start-0">min</span>
                            </div>
                            <div class="text-muted small">
                                Recommended: <span class="badge bg-primary-soft text-primary border border-primary border-opacity-25 px-2">15</span>, <span class="badge bg-primary-soft text-primary border border-primary border-opacity-25 px-2">20</span>, or <span class="badge bg-primary-soft text-primary border border-primary border-opacity-25 px-2">30</span> minutes per appointment.
                            </div>
                        </div>
                        <span asp-validation-for="SlotDurationMinutes" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 pt-3 border-top">
                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">
                    <i class="bi bi-check2 me-2"></i> Save Schedule
                </button>
                <a asp-action="Dashboard" asp-route-id="@Model.DoctorId" class="btn btn-outline-secondary btn-lg fw-bold px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
