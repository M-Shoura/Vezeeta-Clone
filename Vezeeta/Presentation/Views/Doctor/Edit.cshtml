@model Presentation.ViewModels.EditDoctorViewModel

@{
    ViewData["Title"] = "Edit Doctor";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white p-4 rounded-top-4">

                    <h2 class="mb-0 fw-bold">
                        Edit Doctor Profile
                    </h2>

                </div>

                <div class="card-body p-5">

                    <form asp-action="Edit"
                          method="post">

                        <input type="hidden"
                               asp-for="ApplicationUserId" />

                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <input type="hidden"
                               asp-for="FullName" />

                        <input type="hidden"
                               asp-for="ProfilePicture" />

                        <div asp-validation-summary="All"
                             class="alert alert-danger">
                        </div>

                        <!-- PROFILE SECTION -->

                        <div class="text-center mb-5">

                            <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 150)"
                                 class="rounded-circle shadow"
                                 width="150"
                                 height="150"
                                 style="object-fit:cover;" />

                            <h3 class="mt-3 fw-bold">
                                @Model.FullName
                            </h3>

                        </div>

                        <!-- SPECIALIZATION -->

                        <div class="mb-4">

                            <label asp-for="Specialization"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Specialization"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Specialization"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- EXPERIENCE -->

                        <div class="mb-4">

                            <label asp-for="YearsOfExperience"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="YearsOfExperience"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="YearsOfExperience"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- QUALIFICATION -->

                        <div class="mb-4">

                            <label asp-for="Qualification"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Qualification"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="Qualification"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- LICENSE -->

                        <div class="mb-4">

                            <label asp-for="LicenseNumber"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="LicenseNumber"
                                   class="form-control form-control-lg" />

                            <span asp-validation-for="LicenseNumber"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- BIO -->

                        <div class="mb-4">

                            <label asp-for="Bio"
                                   class="form-label fw-bold">
                            </label>

                            <textarea asp-for="Bio"
                                      rows="5"
                                      class="form-control">
                            </textarea>

                            <span asp-validation-for="Bio"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- AVAILABLE -->

                        <div class="form-check form-switch mb-4">

                            <input asp-for="IsAvailable"
                                   class="form-check-input" />

                            <label asp-for="IsAvailable"
                                   class="form-check-label fw-bold">
                                Available For Appointments
                            </label>

                        </div>

                        <!-- BUTTONS -->

                        <div class="d-flex gap-3">

                            <button type="submit"
                                    class="btn btn-primary btn-lg px-5">

                                Save Changes

                            </button>

                            <a class="btn btn-outline-secondary btn-lg px-5" href="@(ViewData["ReturnUrl"] ?? Url.Action("Index","Doctor"))">

                                Cancel

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
