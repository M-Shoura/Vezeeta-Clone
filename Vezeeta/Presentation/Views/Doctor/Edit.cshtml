@model Presentation.ViewModels.EditDoctorViewModel

@{
    ViewData["Title"] = "Edit Doctor";
}

<div class="app-container" style="max-width: 800px; margin: 0 auto;">
    <div class="page-header animate-in border-bottom pb-3 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-light text-muted mb-3 shadow-sm border fw-medium"><i class="bi bi-arrow-left me-1"></i> Back to Doctors</a>
        <h1 class="page-title"><i class="bi bi-person-gear me-2 text-primary"></i> Edit Doctor Profile</h1>
        <p class="page-subtitle">Update professional details and availability.</p>
    </div>

    <div class="section-card p-4 p-md-5 animate-in stagger-1">
        <form asp-action="Edit" method="post" class="needs-validation">
            <input type="hidden" asp-for="ApplicationUserId" />
            <input type="hidden" asp-for="FullName" />
            <input type="hidden" asp-for="ProfilePicture" />

            <div asp-validation-summary="All" class="alert alert-danger shadow-sm d-none"></div>

            <div class="text-center mb-5 pb-4 border-bottom">
                <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 150)"
                     class="rounded-circle shadow-sm border border-4 border-white mb-3"
                     style="width: 120px; height: 120px; object-fit:cover;" />
                <h3 class="fw-bold text-body mb-0">@Model.FullName</h3>
                <span class="badge bg-primary-soft text-primary mt-2 px-3 py-1 border border-primary border-opacity-25">Provider Account</span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label asp-for="Specialization" class="form-label fw-bold">Specialization <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-award"></i></span>
                            <input asp-for="Specialization" class="form-control border-start-0 ps-0 bg-light" placeholder="e.g. Cardiology" />
                        </div>
                        <span asp-validation-for="Specialization" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label asp-for="YearsOfExperience" class="form-label fw-bold">Years of Experience <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-briefcase"></i></span>
                            <input asp-for="YearsOfExperience" class="form-control border-start-0 ps-0 bg-light" />
                        </div>
                        <span asp-validation-for="YearsOfExperience" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label asp-for="Qualification" class="form-label fw-bold">Qualification <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-mortarboard"></i></span>
                            <input asp-for="Qualification" class="form-control border-start-0 ps-0 bg-light" placeholder="e.g. MD, PhD" />
                        </div>
                        <span asp-validation-for="Qualification" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group position-relative">
                        <label asp-for="LicenseNumber" class="form-label fw-bold">License Number</label>
                        <div class="input-group input-group-lg shadow-sm rounded-md overflow-hidden">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-file-earmark-medical"></i></span>
                            <input asp-for="LicenseNumber" class="form-control border-start-0 ps-0 bg-light" placeholder="Medical license ID" />
                        </div>
                        <span asp-validation-for="LicenseNumber" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label asp-for="Bio" class="form-label fw-bold">Professional Bio</label>
                        <textarea asp-for="Bio" class="form-control bg-light shadow-sm" rows="5" placeholder="Tell patients about your expertise..."></textarea>
                        <span asp-validation-for="Bio" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>
                
                <div class="col-md-12">
                    <div class="form-check form-switch p-4 bg-surface-soft rounded-4 border">
                        <input asp-for="IsAvailable" class="form-check-input fs-4 ms-0 me-3" type="checkbox" role="switch" />
                        <label asp-for="IsAvailable" class="form-check-label pt-1 fw-bold fs-5 cursor-pointer">Available For Appointments</label>
                        <div class="text-muted mt-1 ms-5 ps-2">If turned off, patients will not be able to book new slots with you.</div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 pt-3 border-top">
                <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">
                    <i class="bi bi-check2 me-2"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
