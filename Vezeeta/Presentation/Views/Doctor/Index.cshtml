@model IEnumerable<Application.DTOs.Doctors.DoctorDto>

@{
    ViewData["Title"] = "Doctors";
    var clinics = ViewBag.Clinics as IEnumerable<Domain.Entities.Clinic>;
    var isAdmin = User.IsInRole("Admin");
}

<style>
    .doctor-card .btn {
        position: relative;
        z-index: 2;
    }

    .doctor-card .card-body {
        position: relative;
    }
</style>

<div class="app-container">
    <section class="hero-panel p-4 p-xl-5 mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <span class="eyebrow text-white-50">
                    <i class="bi bi-search-heart"></i> Doctor marketplace
                </span>

                <h1 class="display-6 fw-bold mt-3 mb-2">
                    Find the right specialist for your next visit.
                </h1>

                <p class="text-white-50 mb-0">
                    Search doctors by name or specialization and compare availability in a cleaner experience.
                </p>
            </div>

            <div class="col-lg-5">
                <form method="get" asp-action="Index" class="glass-panel p-3">
                    <div class="d-grid gap-2">
                        <input type="text"
                               name="name"
                               value="@ViewBag.Name"
                               class="form-control form-control-lg"
                               placeholder="Search by doctor name" />

                        <select name="specialization"
                                asp-items="ViewBag.Specializations"
                                class="form-select form-select-lg">
                            <option value="">All specializations</option>
                        </select>

                        <button type="submit" class="btn btn-warning btn-lg">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <div class="page-header">
        <div>
            <h2 class="page-title">Doctors</h2>

            <p class="page-subtitle">
                Verified providers, profiles, schedules, and clinic assignments.
            </p>
        </div>

        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Add Doctor
            </a>
        }
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            foreach (var doctor in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="doctor-card card border-0 h-100 position-relative">

                        <div class="card-body p-4">

                            <!-- Clickable Area -->
                            <a asp-action="Details"
                               asp-route-id="@doctor.Id"
                               class="text-decoration-none text-dark">

                                <div class="d-flex align-items-start gap-3">
                                    <img src="@ProfilePictureHelper.GetUrl(doctor.ProfilePicture, doctor.FullName, size: 160)"
                                         class="avatar-lg"
                                         alt="@doctor.FullName" />

                                    <div class="min-w-0">
                                        <h4 class="h5 fw-bold mb-1">
                                           Dr. @doctor.FullName
                                        </h4>

                                        <span class="status-badge status-muted">
                                            @doctor.Specialization
                                        </span>

                                        <p class="text-muted mt-3 mb-2">
                                            @doctor.YearsOfExperience years experience
                                        </p>

                                        <span class="status-badge @(doctor.IsAvailable ? "status-success" : "status-danger")">
                                            @(doctor.IsAvailable ? "Available" : "Not Available")
                                        </span>
                                    </div>
                                </div>
                            </a>

                            <!-- Admin Buttons -->
                            <div class="d-flex flex-wrap gap-2 mt-4 position-relative z-3">

                                @if (isAdmin)
                                {
                                    <a asp-action="Dashboard"
                                       asp-route-id="@doctor.Id"
                                       class="btn btn-primary btn-sm">
                                        <i class="bi bi-grid"></i> Dashboard
                                    </a>

                                    <a asp-controller="Account"
                                       asp-action="EditUser"
                                       asp-route-id="@doctor.Id"
                                       class="btn btn-outline-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@doctor.Id"
                                       class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>

                                    <a asp-action="AddSchedule"
                                       asp-route-doctorId="@doctor.Id"
                                       class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-calendar-plus"></i> Schedule
                                    </a>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <i class="bi bi-search"></i>

                    <p class="mt-2 mb-0">
                        No doctors found.
                    </p>
                </div>
            </div>
        }
    </div>

    <div class="page-header mt-5">
        <div>
            <h2 class="page-title">Clinics</h2>

            <p class="page-subtitle">
                Care locations connected to the doctor network.
            </p>
        </div>
    </div>

    <div class="row g-4">
        @if (clinics != null && clinics.Any())
        {
            foreach (var clinic in clinics)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="clinic-card card h-100">
                        <div class="card-body p-4">

                            <span class="icon-box teal mb-3">
                                <i class="bi bi-hospital"></i>
                            </span>

                            <h4 class="h5 fw-bold">
                                @clinic.Name
                            </h4>

                            <p class="text-muted mb-3">
                                @clinic.Address
                            </p>

                            <div class="d-flex align-items-center gap-2 text-muted">
                                <i class="bi bi-telephone"></i>

                                <span>
                                    @clinic.PhoneNumber
                                </span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    No clinics available.
                </div>
            </div>
        }
    </div>
</div>