@model IEnumerable<Application.DTOs.Prescriptions.PrescriptionDto>

@{
    ViewData["Title"] = "Prescriptions";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-prescription2"></i> Treatment plans</span>
            <h1 class="page-title mt-2">Prescriptions</h1>
            <p class="page-subtitle">Create prescriptions and review recent medication plans.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="section-card p-4">
                <partial name="_PrescriptionForm" model="new Application.DTOs.Prescriptions.PrescriptionDto()" />
            </div>
        </div>

        <div class="col-lg-7">
            <div class="section-card p-4" id="prescriptionsList">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Prescriptions List</h5>
                    <span class="status-badge status-muted">@(Model?.Count() ?? 0) records</span>
                </div>

                @if (Model != null && Model.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Notes</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="prescriptionsTable">
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.PrescriptionDate.ToString("MMM dd, yyyy")</td>
                                    <td><span class="status-badge status-muted">@item.Items?.Count()</span></td>
                                    <td>@(item.Notes?.Substring(0, Math.Min(30, item.Notes.Length)) ?? "N/A")...</td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-warning" onclick="editPrescription(@item.Id)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deletePrescription(@item.Id)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-prescription2"></i>
                        <p class="mt-2 mb-0">No prescriptions found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editPrescription(id) {
            console.log("Edit prescription:", id);
        }

        function deletePrescription(id) {
            if (confirm("Are you sure you want to delete this prescription?")) {
                console.log("Delete prescription:", id);
            }
        }
    </script>
}
