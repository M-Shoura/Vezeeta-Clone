@model IEnumerable<Application.DTOs.Prescriptions.PrescriptionDto>

@{
    ViewData["Title"] = "Prescriptions";
}

<div class="container mt-4">
    <div class="row">
        <!-- Form Section (Left) -->
        <div class="col-lg-5">
            <partial name="_PrescriptionForm" model="new Application.DTOs.Prescriptions.PrescriptionDto()" />
        </div>

        <!-- Prescriptions List (Right) -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Prescriptions List</h5>
                </div>
                <div class="card-body" id="prescriptionsList">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Items</th>
                                        <th>Notes</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="prescriptionsTable">
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.PrescriptionDate.ToString("MMM dd, yyyy")</td>
                                            <td>@item.Items?.Count()</td>
                                            <td>@(item.Notes?.Substring(0, Math.Min(30, item.Notes.Length)) ?? "N/A")...</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-warning" 
                                                        onclick="editPrescription(@item.Id)">
                                                    Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-danger"
                                                        onclick="deletePrescription(@item.Id)">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No prescriptions found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editPrescription(id) {
            // Load prescription and populate form
            console.log('Edit prescription:', id);
        }

        function deletePrescription(id) {
            if (confirm('Are you sure you want to delete this prescription?')) {
                // Delete logic
                console.log('Delete prescription:', id);
            }
        }
    </script>
}
