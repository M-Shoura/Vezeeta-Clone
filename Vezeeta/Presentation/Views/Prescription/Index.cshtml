@model IEnumerable<Application.DTOs.Prescriptions.PrescriptionDto>

@{
    ViewData["Title"] = "Prescriptions";
}

<div class="app-container">
    <div class="page-header animate-in border-bottom pb-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary-soft text-primary p-3 rounded-4">
                <i class="bi bi-prescription2 fs-2"></i>
            </div>
            <div>
                <span class="eyebrow"><i class="bi bi-capsule text-info"></i> Treatment plans</span>
                <h1 class="page-title mt-1 mb-1">Prescriptions</h1>
                <p class="page-subtitle">Review recent medication plans issued during appointments.</p>
            </div>
        </div>
    </div>

    <div class="row g-4 animate-in stagger-1">
        <div class="col-12">
            <div class="section-card p-4" id="prescriptionsList">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Prescriptions List</h5>
                    <span class="badge bg-surface-soft text-body border px-3 py-2 shadow-sm"><i class="bi bi-files me-1 text-muted"></i> @(Model?.Count() ?? 0) records</span>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive border-0">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Date Issued</th>
                                    <th class="text-center">Items</th>
                                    <th>Notes</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="prescriptionsTable">
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold text-body">@item.PrescriptionDate.ToString("dd MMM yyyy")</div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-primary-soft text-primary px-2 py-1 rounded-circle fs-6">@item.Items?.Count()</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <span class="text-truncate d-inline-block text-muted" style="max-width: 150px;" title="@item.Notes">
                                                    @item.Notes
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted opacity-50">N/A</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                @if (User.IsInRole("Patient") || User.IsInRole("patient"))
                                                {
                                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border shadow-sm fw-medium">
                                                        <i class="bi bi-eye text-primary"></i> Details
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border shadow-sm fw-medium" title="View Details">
                                                        <i class="bi bi-eye text-primary"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning shadow-sm" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <button type="button" class="btn btn-sm btn-outline-danger shadow-sm" onclick="deletePrescription(@item.Id)" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state border-0 py-5">
                        <i class="bi bi-prescription2 text-muted opacity-25" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold mt-3 text-body">No prescriptions found</h5>
                        <p class="text-muted mb-0">No treatment plans have been recorded yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deletePrescription(id) {
            if (confirm("Are you sure you want to delete this prescription?")) {
                // To be implemented by backend logic, typically a form POST.
                // For now, redirect to a delete endpoint if it exists, or submit a form.
                window.location.href = '/Prescription/Delete/' + id; 
            }
        }
    </script>
}
