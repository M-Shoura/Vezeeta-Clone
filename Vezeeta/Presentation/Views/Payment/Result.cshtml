@model Presentation.ViewModels.Payments.PaymentResultViewModel

@{
    ViewData["Title"] = "Payment Result";
    var alertClass = Model.IsSuccess ? "alert-success" : "alert-danger";
    var heading = Model.IsSuccess ? "Payment Successful" : "Payment Failed";
}

<div class="card shadow-sm border-0 rounded-4 mx-auto" style="max-width: 760px;">
    <div class="card-body p-4 p-md-5">
        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h2 class="mb-2">@heading</h2>
                <div class="alert @alertClass mb-0" role="alert">
                    @Model.Message
                </div>
            </div>

            <span class="badge rounded-pill @(Model.IsSuccess ? "bg-success" : "bg-danger") fs-6 px-3 py-2">
                @(Model.IsSuccess ? "Completed" : "Failed")
            </span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100 bg-light">
                    <h5 class="mb-3">Appointment</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Doctor</dt>
                        <dd class="col-sm-7 mb-2">@Model.DoctorName</dd>

                        <dt class="col-sm-5 text-muted">Clinic</dt>
                        <dd class="col-sm-7 mb-0">@Model.ClinicName</dd>
                    </dl>
                </div>
            </div>

            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100 bg-light">
                    <h5 class="mb-3">Payment</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Amount</dt>
                        <dd class="col-sm-7 mb-2">@Model.Amount.ToString("N2") EGP</dd>

                        <dt class="col-sm-5 text-muted">Method</dt>
                        <dd class="col-sm-7 mb-2">@Model.PaymentMethod</dd>

                        <dt class="col-sm-5 text-muted">Status</dt>
                        <dd class="col-sm-7 mb-2">@Model.Status</dd>

                        <dt class="col-sm-5 text-muted">Paid at</dt>
                        <dd class="col-sm-7 mb-0">@(Model.PaidAt?.ToString("dddd, MMMM d, yyyy h:mm tt") ?? "Not available")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-primary px-4" asp-controller="Home" asp-action="Index">
                Return to Home
            </a>
        </div>
    </div>
</div>