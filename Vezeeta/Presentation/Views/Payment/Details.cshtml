@model Application.DTOs.Payments.PaymentDto

@{
    ViewData["Title"] = "Payment Details";
}

<h2>Payment Details</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@Model.Amount.ToString("C")</dd>

        <dt class="col-sm-2">Method</dt>
        <dd class="col-sm-10">@Model.PaymentMethod</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Appointment</dt>
        <dd class="col-sm-10">@Model.AppointmentId</dd>

        <dt class="col-sm-2">Doctor</dt>
        <dd class="col-sm-10">@Model.DoctorName</dd>

        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.PatientName</dd>

        <dt class="col-sm-2">Clinic</dt>
        <dd class="col-sm-10">@Model.ClinicName</dd>

        <dt class="col-sm-2">Transaction</dt>
        <dd class="col-sm-10">@Model.TransactionReference</dd>

        <dt class="col-sm-2">Failure Reason</dt>
        <dd class="col-sm-10">@Model.FailureReason</dd>

        <dt class="col-sm-2">Created</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToLocalTime().ToString("f")</dd>
    </dl>

    <p>
        <a class="btn btn-secondary" asp-action="Index">Back to list</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    </p>
</div>