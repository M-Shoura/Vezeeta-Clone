@model IEnumerable<Application.DTOs.Profiles.Patients.PatientProfileDto>

@{
    ViewData["Title"] = "Patients";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-people"></i> Patient registry</span>
            <h1 class="page-title mt-2">Patients</h1>
            <p class="page-subtitle">Manage profiles, contact information, and patient records.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Patient" asp-action="Create">
            <i class="bi bi-person-plus"></i> Add Patient
        </a>
    </div>

    <div class="section-card p-4">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Birth Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var patient in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@ProfilePictureHelper.GetUrl(patient.ProfilePicture, patient.FullName, size: 80)"
                                         class="avatar-sm" alt="@patient.FullName" />
                                    <strong>@patient.FullName</strong>
                                </div>
                            </td>
                            <td>@patient.Email</td>
                            <td>@patient.PhoneNumber</td>
                            <td>@patient.BirthDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Patient" asp-action="Details" asp-route-id="@patient.Email">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                <a class="btn btn-sm btn-outline-warning" asp-controller="Patient" asp-action="Edit" asp-route-id="@patient.Email">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Patient" asp-action="Delete" asp-route-id="@patient.Email">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state my-2">
                                <i class="bi bi-person-x"></i>
                                <p class="mt-2 mb-0">No patients found.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
