@model IEnumerable<Application.DTOs.Profiles.Patients.PatientDto>

@{
    ViewData["Title"] = "Patients";
}

<div class="app-container">

    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-people"></i> Patient registry</span>
            <h1 class="page-title mt-2">Patients</h1>
            <p class="page-subtitle">Registered patient profiles, contact information, and medical records.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Patient" asp-action="Create">
            <i class="bi bi-person-plus"></i> Add Patient
        </a>
    </div>

    <div class="row g-4">
        @if (Model.Any())
        {
            foreach (var patient in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="doctor-card card border-0 h-100 position-relative">
                        <div class="card-body p-4">

                            <!-- Info area -->
                            <a asp-controller="Patient"
                               asp-action="Details"
                               asp-route-id="@patient.ApplicationUserId"
                               class="text-decoration-none text-dark">
                                <div class="d-flex align-items-start gap-3">
                                    <img src="@ProfilePictureHelper.GetUrl(patient.ProfilePicture, patient.FullName, size: 160)"
                                         class="avatar-lg"
                                         alt="@patient.FullName" />

                                    <div class="min-w-0">
                                        <h4 class="h5 fw-bold mb-1">@patient.FullName</h4>

                                        <span class="status-badge status-muted">
                                            @patient.Gender
                                        </span>

                                        <p class="text-muted mt-2 mb-1 small">
                                            <i class="bi bi-envelope"></i> @patient.Email
                                        </p>

                                        @if (!string.IsNullOrEmpty(patient.PhoneNumber))
                                        {
                                            <p class="text-muted mb-1 small">
                                                <i class="bi bi-telephone"></i> @patient.PhoneNumber
                                            </p>
                                        }

                                        @if (!string.IsNullOrEmpty(patient.BloodType))
                                        {
                                            <span class="status-badge status-danger">
                                                🩸 @patient.BloodType
                                            </span>
                                        }
                                    </div>
                                </div>
                            </a>

                            <!-- Admin action buttons — same pattern as Doctor/Index.cshtml -->
                            <div class="d-flex flex-wrap gap-2 mt-4 position-relative z-3">

                                <a asp-controller="Account"
                                   asp-action="EditUser"
                                   asp-route-id="@patient.ApplicationUserId"
                                   class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                               

                                <a asp-controller="Patient"
                                   asp-action="Delete"
                                   asp-route-id="@patient.ApplicationUserId"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </a>

                            </div>
                        </div>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <i class="bi bi-person-x"></i>
                    <p class="mt-2 mb-0">No patients found.</p>
                </div>
            </div>
        }
    </div>

</div>
