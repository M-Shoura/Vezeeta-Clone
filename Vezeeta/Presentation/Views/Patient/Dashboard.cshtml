@model Application.DTOs.Dashboards.PatientDashboardViewModel

@{
    ViewData["Title"] = "Patient Dashboard";
    Layout = "_Layout";
}

<div class="app-container">
    <section class="hero-panel p-4 p-xl-5 mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <span class="eyebrow text-white-50"><i class="bi bi-heart-pulse"></i> Patient home</span>
                <h1 class="display-6 fw-bold mt-3 mb-2">Welcome back, @Model.FullName</h1>
                <p class="mb-0 text-white-50">Track real appointments, prescriptions, medical history, and reminders from your care dashboard.</p>
            </div>
            <div class="col-lg-4">
                <div class="glass-panel p-3">
                    <div class="d-flex align-items-center gap-3">
                        <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 120)"
                             class="avatar-lg border border-3 border-white" alt="@Model.FullName" />
                        <div>
                            <small class="text-white-50 fw-bold">Profile completion</small>
                            <div class="h3 fw-bold mb-2">@Model.ProfileCompletion%</div>
                            <div class="progress progress-soft bg-white bg-opacity-25">
                                <div class="progress-bar" role="progressbar" style="width:@Model.ProfileCompletion%" aria-valuenow="@Model.ProfileCompletion" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Upcoming</p>
                <h2 class="metric-value">@Model.UpcomingAppointmentsCount</h2>
                <span class="metric-trend">Booked visits</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">History</p>
                <h2 class="metric-value">@Model.AppointmentHistoryCount</h2>
                <span class="metric-trend">Previous visits</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Prescriptions</p>
                <h2 class="metric-value">@Model.PrescriptionCount</h2>
                <span class="metric-trend">Medication plans</span>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="metric-card">
                <p class="metric-label">Medical Records</p>
                <h2 class="metric-value">@Model.MedicalRecordCount</h2>
                <span class="metric-trend">Clinical summaries</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="section-card p-4 mb-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">Upcoming Appointments</h5>
                        <p class="text-muted mb-0">Your next visits and booking status.</p>
                    </div>
                    @* <a asp-action="Appointments" class="btn btn-outline-primary btn-sm">View All</a> *@
                </div>

                @if (Model.UpcomingAppointments.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var appointment in Model.UpcomingAppointments)
                        {
                            var statusClass = appointment.Status == Domain.Enums.AppointmentStatus.Confirmed
                                ? "status-success"
                                : appointment.Status == Domain.Enums.AppointmentStatus.Pending ? "status-warning" : "status-muted";

                            <article class="appointment-card card p-3">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="icon-box"><i class="bi bi-person-vcard"></i></span>
                                        <div>
                                            <h6 class="fw-bold mb-1">@appointment.DoctorName</h6>
                                            <small class="text-muted">@appointment.ClinicName • @appointment.AppointmentDate.ToString("dd MMM yyyy"), @appointment.StartTime.ToString(@"hh\:mm")</small>
                                        </div>
                                    </div>
                                    <span class="status-badge @statusClass">@appointment.Status</span>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-plus"></i>
                        <p class="mt-2 mb-3">No upcoming appointments yet.</p>
                        <a asp-controller="Doctor" asp-action="Index" class="btn btn-primary">Book an Appointment</a>
                    </div>
                }
            </div>

            <div class="section-card p-4">
                <h5 class="fw-bold mb-3">Recent Prescriptions</h5>
                @if (Model.Prescriptions.Any())
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Doctor</th>
                                <th>Items</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prescription in Model.Prescriptions)
                            {
                                <tr>
                                    <td>@prescription.PrescriptionDate.ToString("dd MMM yyyy")</td>
                                    <td>@prescription.DoctorName</td>
                                    <td><span class="status-badge status-muted">@prescription.ItemsCount</span></td>
                                    <td>@(prescription.Notes ?? "N/A")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">No prescriptions found.</div>
                }
            </div>
        </div>

        <div class="col-xl-4">
            <div class="section-card p-4 mb-4">
                <h5 class="fw-bold mb-3">Health Summary</h5>
                <div class="d-grid gap-3">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Phone</span>
                        <strong>@(Model.PhoneNumber ?? "Not added")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Birth Date</span>
                        <strong>@Model.DateOfBirth.ToString("dd MMM yyyy")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Blood type</span>
                        <strong>@(Model.BloodType ?? "Not added")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Favorite doctors</span>
                        <strong>@Model.FavoriteDoctorsCount</strong>
                    </div>
                </div>
                <div class="d-grid mt-4">
                    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-primary">Complete Profile</a>
                </div>
            </div>

            <div class="section-card p-4 mb-4">
                <h5 class="fw-bold mb-3">Medical Summaries</h5>
                @if (Model.MedicalSummaries.Any())
                {
                    <div class="d-grid gap-2">
                        @foreach (var summary in Model.MedicalSummaries)
                        {
                            <div class="p-3 rounded-4 bg-light">
                                <div class="d-flex justify-content-between gap-2">
                                    <strong>@summary.Condition</strong>
                                    <span class="status-badge @(summary.IsActive ? "status-success" : "status-muted")">
                                        @(summary.IsActive ? "Active" : "Resolved")
                                    </span>
                                </div>
                                <small class="text-muted">@summary.DiagnosedDate.ToString("dd MMM yyyy")</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">No medical summaries found.</div>
                }
            </div>

            <div class="section-card p-4">
                <h5 class="fw-bold mb-3">Care Shortcuts</h5>
                <div class="d-grid gap-2">
                    <a asp-controller="Doctor" asp-action="Index" class="btn quick-action">
                        <i class="bi bi-calendar-plus text-primary"></i> Book appointment
                    </a>
                    <a asp-controller="MedicalRecord" asp-action="Index" class="btn quick-action">
                        <i class="bi bi-file-medical text-success"></i> Medical history
                    </a>
                    <a asp-controller="Prescription" asp-action="Index" class="btn quick-action">
                        <i class="bi bi-prescription2 text-info"></i> Prescriptions
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
