@model Application.DTOs.Profiles.Patients.PatientProfileDto

<h2>Patient Details</h2>

<div class="card p-3">
    <div class="d-flex align-items-center gap-3">
        <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 120)"
             class="rounded-circle shadow-sm"
             width="90"
             height="90"
             style="object-fit:cover;" />
        <h3 class="mb-0">@Model.FullName</h3>
    </div>

    <hr />

    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Phone:</strong> @Model.PhoneNumber</p>
    <p><strong>Birth Date:</strong> @Model.BirthDate.ToString("dd/MM/yyyy")</p>

    <a class="btn btn-primary"
       href="/Patient/Edit/@Model.Email">Edit</a>

    <a class="btn btn-secondary"
       href="/Patient">Back to List</a>
</div>
