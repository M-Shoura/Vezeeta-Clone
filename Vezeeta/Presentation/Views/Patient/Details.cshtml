@model Application.DTOs.Profiles.Patients.PatientDto

@{
    ViewData["Title"] = "Patient Details";
}

<div class="app-container">
    <div class="page-header">
        <div>
            <span class="eyebrow"><i class="bi bi-person"></i> Patient registry</span>
            <h1 class="page-title mt-2">Patient Details</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Patients
        </a>
    </div>

    <div class="section-card p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
            <img src="@ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 120)"
                 class="rounded-circle shadow-sm"
                 width="90"
                 height="90"
                 style="object-fit:cover;" />
            <div>
                <h3 class="mb-0">@Model.FullName</h3>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <hr />

        <div class="row g-3">
            <div class="col-md-6">
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.PhoneNumber</p>
                <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToString("dd/MM/yyyy")</p>
            </div>
            <div class="col-md-6">
                <p><strong>Gender:</strong> @Model.Gender</p>
                <p><strong>Blood Type:</strong> @(Model.BloodType ?? "—")</p>
                <p><strong>Emergency Contact:</strong> @(Model.EmergencyContactName ?? "—") — @(Model.EmergencyContactPhone ?? "—")</p>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.ApplicationUserId">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
        </div>
    </div>
</div>

