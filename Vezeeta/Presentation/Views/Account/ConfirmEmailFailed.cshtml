@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card shadow text-center">

    <div class="card-body p-5">

        <i class="bi bi-x-circle display-1 text-danger"></i>

        <h2 class="mt-4">Email Confirmation Failed</h2>

        <p class="text-muted">
            @ViewData["Error"]
        </p>

        <a asp-action="Login"
               class="btn btn-primary mt-3">
            Back to Login
        </a>

    </div>
</div>