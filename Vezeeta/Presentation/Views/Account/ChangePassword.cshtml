@model Application.DTOs.Auth.ChangePasswordDto

@{
    ViewData["Title"] = "Change Password";
}

<div class="app-container">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <div class="page-header">
                <div>
                    <span class="eyebrow"><i class="bi bi-lock"></i> Security</span>
                    <h1 class="page-title mt-2">Change Password</h1>
                    <p class="page-subtitle">Update your account password without changing your profile details.</p>
                </div>
            </div>

            <div class="section-card p-4 p-lg-5">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label"></label>
                        <input asp-for="CurrentPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-shield-check"></i> Change Password
                        </button>
                        <a asp-action="Profile" class="btn btn-light">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
