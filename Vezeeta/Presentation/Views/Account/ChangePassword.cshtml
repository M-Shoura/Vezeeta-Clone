@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3">
            <nav class="list-group rounded-3">
                <a asp-action="Profile" class="list-group-item list-group-item-action text-muted"><h5>Profile</h5></a>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action active"><h5>Change Password</h5></a>
                <a asp-action="Appointments" class="list-group-item list-group-item-action text-muted"><h5>Appointments</h5></a>
                <a asp-action="Logout" class="list-group-item list-group-item-action text-white bg-danger"><h5>Logout</h5></a>
            </nav>
        </div>

        <!-- Form Content -->
        <div class="col-md-7">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-primary text-light text-center">
                    <h5 class="mb-0">Change Password</h5>
                </div>
                <div class="card-body p-8">
                    <form asp-action="ChangePassword" method="post" id="changePasswordForm">
                        
                        <!-- Current Password -->
                        <div class="form-group mb-4">
                            <label asp-for="CurrentPassword" class="form-label">Current Password <span class="text-danger">*</span></label>
                            <input asp-for="CurrentPassword" type="password" class="form-control" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <!-- New Password -->
                        <div class="form-group mb-4">
                            <label asp-for="NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                            <input asp-for="NewPassword" type="password" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-danger">Save</button>
                            <a class="btn btn-light" asp-controller="Home"  asp-action="Index"class="text-danger">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
