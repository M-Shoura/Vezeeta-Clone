@model Application.DTOs.Auth.ForgotPasswordDto

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card auth-card shadow-lg">
    <div class="auth-header">
        <span class="eyebrow"><i class="bi bi-shield-lock"></i> Account recovery</span>
        <h2 class="mt-2">Forgot password?</h2>
        <p class="mb-0">Enter your email and we will send a secure reset link.</p>
    </div>

    <div class="card-body p-4 p-lg-5">
        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-send"></i> Send Reset Link
            </button>

            <div class="text-center mt-4">
                <a asp-action="Login">Back to login</a>
            </div>
        </form>
    </div>
</div>
