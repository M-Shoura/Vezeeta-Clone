@model ProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-md-3">
            <nav class="list-group rounded-3">
                <a asp-action="Profile" class="list-group-item list-group-item-action active"><h5>Profile</h5></a>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action text-muted"><h5>Change Password</h5></a>
                <a asp-action="Appointments" class="list-group-item list-group-item-action text-muted"><h5>Appointments</h5></a>
                <a asp-action="Logout" class="list-group-item list-group-item-action text-white bg-danger"><h5>Logout</h5></a>
            </nav>
        </div>

        <!-- Form Content -->
        <div class="col-md-7">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-primary text-light text-center">
                    <h5 class="mb-0">Manage Profile</h5>
                </div>
                <div class="card-body p-8">
                    <form asp-action="Profile" method="post" id="profileForm">
                        
                        <!-- Full Name -->
                        <div class="form-group mb-4">
                            <label asp-for="FullName" class="form-label">Your Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="First name and Last name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- Email Address -->
                        <div class="form-group mb-4">
                            <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Mobile Number (International Input) -->
                        <div class="form-group mb-4">
                            <label asp-for="PhoneNumber" class="form-label">Mobile Number <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" type="tel" id="phone" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <!-- BirthDate -->
                        <div class="form-group mb-3">
                            <label asp-for="BirthDate" class="form-label">Birth Date<span class="text-danger">*</span></label>
                            <input asp-for="BirthDate" type="date" class="form-control" />  
                            <span asp-validation-for="BirthDate" class="text-danger small"></span>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-danger">Save</button>
                            <a class="btn btn-light" asp-controller="Home"  asp-action="Index"class="text-danger">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- intl-tel-input logic -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
    
    <script>
        const phoneInput = document.querySelector("#phone");
        window.intlTelInput(phoneInput, {
            initialCountry: "eg", // Egypt as per your HTML
            preferredCountries: ["eg", "jo", "lb", "sa", "ae"],
            utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js",
        });
    </script>
}