@model ProfileViewModel

@{
    var isAdminEdit = !string.IsNullOrEmpty(Model.EditingUserId);
    ViewData["Title"] = isAdminEdit ? "Edit User Profile" : "Profile";
    var initial = !string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName.Substring(0, 1) : "U";
    var profilePictureUrl = ProfilePictureHelper.GetUrl(Model.ProfilePicture, Model.FullName, size: 180);
}

<div class="app-container">
    <div class="row g-4">
        <div class="col-lg-4 col-xl-3">
            <aside class="section-card p-3">
                <div class="d-flex align-items-center gap-3 p-2 mb-3">
                    <img src="@profilePictureUrl" class="avatar-sm" alt="@Model.FullName" style="width:52px;height:52px;object-fit:cover;" />
                    <div>
                        <h5 class="fw-bold mb-0">@Model.FullName</h5>
                        <small class="text-muted">@Model.Email</small>
                    </div>
                </div>
                <nav class="list-group list-group-flush">
                    <a asp-action="Profile" class="list-group-item list-group-item-action active rounded-3">
                        <i class="bi bi-person"></i> Profile
                    </a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action rounded-3">
                        <i class="bi bi-lock"></i> Change Password
                    </a>
                    <a asp-action="Logout" class="list-group-item list-group-item-action rounded-3 text-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </nav>
            </aside>
        </div>

        <div class="col-lg-8 col-xl-7">
            <div class="page-header">
                <div>
                    <span class="eyebrow"><i class="bi bi-person-gear"></i> Account settings</span>
                    <h1 class="page-title mt-2">Manage Profile</h1>
                    <p class="page-subtitle">Keep your contact details accurate for appointments and notifications.</p>
                </div>
            </div>

            <div class="section-card p-4 p-lg-5">
                @if (isAdminEdit)
                {
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-shield-lock"></i> You are editing another user's profile as <strong>Admin</strong>.
                    </div>
                }
                <form asp-action="@(isAdminEdit ? "EditUser" : "Profile")"
                      asp-route-id="@Model.EditingUserId"
                      method="post" enctype="multipart/form-data" id="profileForm">
                    <input type="hidden" asp-for="EditingUserId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="ProfilePicture" />

                    <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
                        <img src="@profilePictureUrl"
                             class="rounded-circle shadow-sm"
                             width="110"
                             height="110"
                             style="object-fit:cover;"
                             alt="@Model.FullName" />
                        <div class="flex-grow-1">
                            <label asp-for="ProfilePictureFile" class="form-label">Profile Picture</label>
                            <input asp-for="ProfilePictureFile" type="file" accept=".jpg,.jpeg,.png,.webp,image/*" class="form-control" />
                            <span asp-validation-for="ProfilePictureFile" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label">Your Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="First name and last name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Mobile Number <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" type="tel" id="phone" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label">Profile Type <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select" id="roleSelect">
                                <option value="@UserRole.Doctor">Doctor</option>
                                <option value="@UserRole.Patient">Patient</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Address</label>
                            <textarea asp-for="Address" rows="2" class="form-control"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                    </div>

                    <div id="patientFields" class="border rounded-3 p-3 mt-4">
                        <h5 class="fw-bold mb-3">Patient Information</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="BirthDate" class="form-label">Birth Date</label>
                                <input asp-for="BirthDate" type="date" class="form-control" />
                                <span asp-validation-for="BirthDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label">Gender</label>
                                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select">
                                    <option value="">Select gender</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="BloodType" class="form-label">Blood Type</label>
                                <input asp-for="BloodType" class="form-control" />
                                <span asp-validation-for="BloodType" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EmergencyContactName" class="form-label">Emergency Contact Name</label>
                                <input asp-for="EmergencyContactName" class="form-control" />
                                <span asp-validation-for="EmergencyContactName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EmergencyContactPhone" class="form-label">Emergency Contact Phone</label>
                                <input asp-for="EmergencyContactPhone" class="form-control" />
                                <span asp-validation-for="EmergencyContactPhone" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div id="doctorFields" class="border rounded-3 p-3 mt-4">
                        <h5 class="fw-bold mb-3">Doctor Information</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Specialization" class="form-label">Specialization</label>
                                <input asp-for="Specialization" class="form-control" />
                                <span asp-validation-for="Specialization" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Qualification" class="form-label">Qualification</label>
                                <input asp-for="Qualification" class="form-control" />
                                <span asp-validation-for="Qualification" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="YearsOfExperience" class="form-label">Years Of Experience</label>
                                <input asp-for="YearsOfExperience" type="number" min="0" max="60" class="form-control" />
                                <span asp-validation-for="YearsOfExperience" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LicenseNumber" class="form-label">License Number</label>
                                <input asp-for="LicenseNumber" class="form-control" />
                                <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Bio" class="form-label">Bio</label>
                                <textarea asp-for="Bio" rows="4" class="form-control"></textarea>
                                <span asp-validation-for="Bio" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input asp-for="IsAvailable" class="form-check-input" />
                                    <label asp-for="IsAvailable" class="form-check-label">Available For Appointments</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2"></i> Save Changes
                        </button>
                        @if (isAdminEdit)
                        {
                            <a class="btn btn-light" asp-controller="Doctor" asp-action="Index">Cancel</a>
                        }
                        else
                        {
                            <a class="btn btn-light" asp-controller="Home" asp-action="Index">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
    <script>
        const roleSelect = document.querySelector("#roleSelect");
        const doctorFields = document.querySelector("#doctorFields");
        const patientFields = document.querySelector("#patientFields");

        function toggleProfileTypeFields() {
            const selectedText = roleSelect.options[roleSelect.selectedIndex].text;

            doctorFields.classList.toggle("d-none", selectedText !== "Doctor");
            patientFields.classList.toggle("d-none", selectedText !== "Patient");
        }

        if (roleSelect) {
            toggleProfileTypeFields();
            roleSelect.addEventListener("change", toggleProfileTypeFields);
        }

        const phoneInput = document.querySelector("#phone");
        if (phoneInput) {
            window.intlTelInput(phoneInput, {
                initialCountry: "eg",
                preferredCountries: ["eg", "jo", "lb", "sa", "ae"],
                utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js",
            });
        }
    </script>
}
