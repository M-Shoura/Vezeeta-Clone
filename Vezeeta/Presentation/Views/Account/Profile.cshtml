@model ProfileViewModel

@{
    ViewData["Title"] = "Profile";
    var initial = !string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName.Substring(0, 1) : "U";
}

<div class="app-container">
    <div class="row g-4">
        <div class="col-lg-4 col-xl-3">
            <aside class="section-card p-3">
                <div class="d-flex align-items-center gap-3 p-2 mb-3">
                    <span class="avatar">@initial</span>
                    <div>
                        <h5 class="fw-bold mb-0">@Model.FullName</h5>
                        <small class="text-muted">@Model.Email</small>
                    </div>
                </div>
                <nav class="list-group list-group-flush">
                    <a asp-action="Profile" class="list-group-item list-group-item-action active rounded-3">
                        <i class="bi bi-person"></i> Profile
                    </a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action rounded-3">
                        <i class="bi bi-lock"></i> Change Password
                    </a>
                    <a asp-action="Logout" class="list-group-item list-group-item-action rounded-3 text-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </nav>
            </aside>
        </div>

        <div class="col-lg-8 col-xl-7">
            <div class="page-header">
                <div>
                    <span class="eyebrow"><i class="bi bi-person-gear"></i> Account settings</span>
                    <h1 class="page-title mt-2">Manage Profile</h1>
                    <p class="page-subtitle">Keep your contact details accurate for appointments and notifications.</p>
                </div>
            </div>

            <div class="section-card p-4 p-lg-5">
                <form asp-action="Profile" method="post" id="profileForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label">Your Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="First name and last name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@domain.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Mobile Number <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" type="tel" id="phone" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BirthDate" class="form-label">Birth Date <span class="text-danger">*</span></label>
                            <input asp-for="BirthDate" type="date" class="form-control" />
                            <span asp-validation-for="BirthDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2"></i> Save Changes
                        </button>
                        <a class="btn btn-light" asp-controller="Home" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
    <script>
        const phoneInput = document.querySelector("#phone");
        if (phoneInput) {
            window.intlTelInput(phoneInput, {
                initialCountry: "eg",
                preferredCountries: ["eg", "jo", "lb", "sa", "ae"],
                utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/utils.js",
            });
        }
    </script>
}
